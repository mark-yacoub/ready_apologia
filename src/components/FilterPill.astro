---
export interface Props {
  href: string;
  title: string;
  count?: number;
  variant?: 'primary' | 'primary-soft';
}

const { href, title, count, variant = 'primary-soft' } = Astro.props;
---
<a href={href} class={`filter-pill ${variant}`}>
  {title} {count !== undefined && count > 0 && <span class={`count-badge ${variant === 'primary' ? 'light' : ''}`}>{count}</span>}
</a>

<style>
  .filter-pill {
    display: inline-flex;
    align-items: center;
    background-color: var(--color-background);
    color: var(--color-on-surface);
    border: 1px solid var(--color-outline-variant);
    border-radius: 20px;
    padding: 0.5rem 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .filter-pill.primary-soft {
    background-color: rgba(11, 102, 59, 0.05);
    border-color: rgba(11, 102, 59, 0.2);
    color: #0b663b;
  }

  .filter-pill.primary-soft:hover {
    background-color: rgba(11, 102, 59, 0.1);
    border-color: rgba(11, 102, 59, 0.3);
  }

  .filter-pill.primary {
    background-color: #0b663b;
    color: white;
    border-color: #0b663b;
  }

  .filter-pill.primary:hover {
    background-color: #084c2c;
  }

  .count-badge {
    background-color: rgba(11, 102, 59, 0.15);
    color: #0b663b;
    font-size: 0.75rem;
    padding: 2px 6px;
    border-radius: 10px;
    margin-left: 8px;
    font-weight: 600;
  }

  .count-badge.light {
    background-color: rgba(255, 255, 255, 0.2);
    color: white;
  }
</style>
