---
const { companionName, companionData, variants, isStandalone } = Astro.props;
const codexVal = `codex-${companionName}`;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

const sortedVariants = variants.sort((a, b) => {
  const getNum = (ref) => {
    const m = ref.match(/\d+/);
    return m ? parseInt(m[0], 10) : 999999;
  };
  const aBukhari = a.source_reference.toLowerCase().includes('bukhari') ? 0 : 1;
  const bBukhari = b.source_reference.toLowerCase().includes('bukhari') ? 0 : 1;
  if (aBukhari !== bBukhari) return aBukhari - bBukhari;
  
  const aMuslim = a.source_reference.toLowerCase().includes('muslim') ? 0 : 1;
  const bMuslim = b.source_reference.toLowerCase().includes('muslim') ? 0 : 1;
  if (aMuslim !== bMuslim) return aMuslim - bMuslim;

  return getNum(a.source_reference) - getNum(b.source_reference);
});
---

<div id={codexVal} class={isStandalone ? "lost-companion-profile" : "lost-companion-group"} data-companion={companionName} style={isStandalone ? "" : "background: var(--color-surface); border: 1px solid var(--color-outline-variant); border-radius: 8px; padding: 16px; transition: border-color 0.2s, box-shadow: 0.2s;"}>
  
  {isStandalone ? (
    <div style="margin-bottom: 24px;">
      <h1 style="margin: 0 0 16px 0; font-family: var(--font-display); font-size: 32px; color: var(--color-secondary);">{companionName.replace(/_/g, ' ')}'s Codex</h1>
    </div>
  ) : (
    <div style="display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--color-outline-variant); padding-bottom: 8px; margin-bottom: 12px;">
      <div style="display: flex; align-items: center; gap: 8px;">
        <h3 style="margin: 0; font-family: var(--font-display); font-size: 18px; color: var(--color-secondary);">{companionName.replace(/_/g, ' ')}</h3>
        {companionData?.virtues.length > 0 && (
          <button class="companion-info-toggle-btn" data-companion={companionName} style="background: none; border: 1px solid var(--color-outline-variant); padding: 4px 8px; border-radius: 6px; font-size: 11px; cursor: pointer; color: var(--color-on-surface-variant); display: flex; align-items: center; gap: 4px;">
            {companionName.includes('Aisha') ? 'ℹ️ Why she matters' : 'ℹ️ Why he matters'}
          </button>
        )}
      </div>
      <a class="read-as-lost-companion-btn" href={`${base}/quran/0/${companionName}`} style="background: var(--color-primary); color: white; border: none; padding: 6px 12px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-block;">
        Read As {companionName.replace(/_/g, ' ')}
      </a>
    </div>
  )}

  {companionData?.virtues.length > 0 && (
    <details open={isStandalone} id={isStandalone ? undefined : `companion-virtues-${companionName}`} class="companion-virtues-panel" style={isStandalone ? "margin-bottom: 32px; padding: 16px; background: var(--color-surface-container-lowest); border: 1px dashed var(--color-outline-variant); border-radius: 8px;" : "display: none; margin-bottom: 16px; padding: 12px; background: var(--color-surface-container-lowest); border: 1px dashed var(--color-outline-variant); border-radius: 6px; font-size: 12.5px;"}>
      <summary class="virtues-summary" style={isStandalone ? "cursor: pointer; color: var(--color-secondary); font-size: 15px; font-weight: 600; margin-bottom: 12px; list-style: none; display: flex; align-items: center; gap: 8px;" : "display: none; cursor: pointer; color: var(--color-secondary); font-size: 13px; font-weight: 600; margin-bottom: 8px;"}>
        {isStandalone ? (
          <span>📖 {companionName.includes('Aisha') ? 'Why she matters (Hadiths)' : 'Why he matters (Hadiths)'}</span>
        ) : (
          "📖 Why they matter (Hadiths)"
        )}
      </summary>
      {companionData.virtues.map(v => (
        <div style={isStandalone ? "margin-top: 16px; border-top: 1px dashed var(--color-outline-variant); padding-top: 12px;" : "margin-bottom: 12px; border-bottom: 1px dashed #f1f5f9; padding-bottom: 8px;"}>
          <div class="hadith-ar" style="direction: rtl; font-family: 'Amiri', serif; font-size: 14px; margin-bottom: 4px; color: var(--color-on-surface); line-height: 1.6; opacity: 0.6; transition: all 0.2s;">{v.hadith_arabic}</div>
          <div class="hadith-en" style="font-family: var(--font-display); font-size: 18px; color: var(--color-on-surface); line-height: 1.5; transition: all 0.2s;">{v.hadith_english}</div>
          <div style={isStandalone ? "margin-top: 4px; font-size: 11px; color: var(--color-on-surface-variant);" : "margin-top: 4px; font-size: 10px; color: var(--color-on-surface-variant);"}>
            Source: <a href={v.sunnah_url} target="_blank" style="text-decoration: underline; color: var(--color-secondary);">{v.source_reference}</a>
          </div>
        </div>
      ))}
    </details>
  )}

  <div style="display: flex; flex-direction: column; gap: 16px;">
    {sortedVariants.map(v => (
      <div class="lost-verse-item" style="border-bottom: 1px dashed var(--color-outline-variant); padding-bottom: 16px;">
        {isStandalone && (
          <h4 style="margin: 0 0 12px 0; font-family: var(--font-display); font-size: 16px; color: var(--color-on-surface-variant); display: flex; align-items: center; gap: 8px;">
            {v.source_reference}
            <a href={v.sunnah_url} target="_blank" style="color: var(--color-primary); display: flex; align-items: center;" aria-label="Go to Source" title="Go to Source">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </h4>
        )}
        <div class="quran-ar" style="direction: rtl; font-family: 'Amiri', serif; font-size: 22px; line-height: 1.8; color: var(--color-primary); text-align: right; margin-bottom: 8px; transition: all 0.2s;">
          {v.variant_arabic}
        </div>
        <div class="quran-en" style="font-family: var(--font-display); font-size: 16px; line-height: 1.6; color: var(--color-on-surface); margin-bottom: 8px; transition: all 0.2s;">
          {v.variant_english}
        </div>
        {v.hadith_english && (
          <div style="background: var(--color-surface-container-low); padding: 12px 16px; border-radius: 8px; margin-top: 12px; border-left: 3px solid var(--color-outline-variant);">
            <div style="font-size: 11px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; color: var(--color-on-surface-variant); margin-bottom: 8px;">Context (Hadith)</div>
            <div class="hadith-ar" style="direction: rtl; font-family: 'Amiri', serif; font-size: 14px; line-height: 1.8; color: var(--color-on-surface); text-align: right; margin-bottom: 8px; opacity: 0.6; transition: all 0.2s;">
              {v.hadith_arabic}
            </div>
            <div class="hadith-en" style="font-family: var(--font-display); font-size: 18px; line-height: 1.6; color: var(--color-on-surface); transition: all 0.2s;">
              {v.hadith_english}
            </div>
          </div>
        )}
        {!isStandalone && (
          <div style="margin-top: 6px; font-size: 11px; color: var(--color-on-surface-variant);">
            Source: <a href={v.sunnah_url} target="_blank" style="text-decoration: underline; color: var(--color-secondary);">{v.source_reference}</a>
          </div>
        )}
      </div>
    ))}
  </div>
</div>
