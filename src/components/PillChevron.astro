---
// Reusable expanding chevron for UI pills
---
<svg class="pill-chevron" aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
  <polyline points="6 9 12 15 18 9"></polyline>
</svg>

<style>
  .pill-chevron {
    width: 14px;
    height: 14px;
    transition: transform 0.2s ease;
    transform-origin: center center;
  }
</style>
