---
import BottomNav from '../components/BottomNav.jsx';
import ScriptureNav from '../components/ScriptureNav.jsx';
import OnboardingModal from '../components/OnboardingModal.jsx';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/markdown-exegesis.css';
import '../styles/evidence-badges.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	schema?: string;
	keywords?: string;
	theme?: string;
}

const { 
	title, 
	description = "Ready Apologia - Defending the Faith with Biblical Scripture and Early Church Fathers", 
	ogImage, 
	schema,
	keywords = "Apologetics, Bible Verses, Early Church Fathers, Divinity of Christ, Ready Apologia, Patristics, Scripture Evidence, Christian Apologetics, Ante-Nicene Fathers",
	theme
} = Astro.props;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const site = Astro.site ? Astro.site.toString().replace(/\/$/, '') : '';
const fallbackImage = `${site}${base}/default-og-image.png`;
const ogImageUrl = ogImage ? (ogImage.startsWith('http') ? ogImage : `${site}${base}${ogImage}`) : fallbackImage;
const ogUrl = new URL(Astro.url.pathname, Astro.site || Astro.url).href;
---

<!doctype html>
<html lang="en" class="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
		<link rel="icon" type="image/png" href={`${base}/assets/logo.png`} />
		<link rel="apple-touch-icon" href={`${base}/assets/logo.png`} />
		<link rel="canonical" href={ogUrl} />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Open Graph / Social Media -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={ogUrl} />
		<meta property="og:title" content={`${title} | Ready Apologia`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={ogUrl} />
		<meta name="twitter:title" content={`${title} | Ready Apologia`} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<title>{title} | Ready Apologia</title>
		
		{schema && <script type="application/ld+json" set:html={schema} />}
		<ClientRouter />
		<GoogleAnalytics />
		
		<!-- Load Google Fonts -->
		<link href="https://fonts.googleapis.com" rel="preconnect"/>
		<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
		<link href="https://fonts.googleapis.com/css2?family=Literata:ital,opsz,wght@0,7..72,200..900;1,7..72,200..900&family=Public+Sans:ital,wght@0,100..900;1,100..900&family=Amiri:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet"/>

		<!-- PWA Manifest & Worker links -->
		<link rel="manifest" href={`${base}/manifest.json`} />
		<meta name="theme-color" content="#18181b" />

		<!-- Register PWA Service Worker -->
		<script is:inline define:vars={{ base }}>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register(`${base}/sw.js`)
						.then(reg => console.log('PWA Service Worker registered successfully!'))
						.catch(err => console.warn('PWA Service Worker registration failed:', err));
				});
			}
		</script>
	</head>
	<body class="bg-slate-100 text-slate-900 min-h-screen flex justify-center items-center transition-colors duration-200">
		
		<!-- App Bounding Container -->
		<div class={`app-container ${theme ? `theme-${theme}` : ''}`}>
			<div id="global-loading-indicator" class="global-loading-indicator"></div>
			
			<!-- Content Layout Core -->
			<div class="content-frame">
				<!-- Header -->
				<header class="app-header">
					<div class="header-left">
						<!-- Collapsible Nav Burger Button -->
						<button id="nav-toggle-btn" class="nav-burger-btn" aria-label="Toggle Navigation Menu">
							<svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
							</svg>
						</button>
						
						<!-- Brand Logo Crest + Typography (Brand ID swap on scroll) -->
						<div class="brand-container">
							<img src={`${base}/assets/logo.png`} alt="Ready Apologia Emblem" class="header-shield-logo" />
							<span class="brand-text" id="header-brand-text" data-original="Ready Apologia">Ready Apologia</span>
						</div>
					</div>
					
					<div class="header-right-spacer"></div>
				</header>

				<!-- Main scrollable content window -->
				<main class="main-content">
					<slot />

					<!-- Footer -->
					<footer class="app-footer">
						<p class="footer-disclaimer">
							Ready Apologia is an actively evolving project. We are continuously adding new theological filters, deep-dive topics, and manuscript data, while rigorously refining our quality checks. If you notice any bugs, misalignments, or have suggestions, please use the feedback links below to help us improve. Expect fresh updates on a biweekly basis!
						</p>
						<div class="footer-links">
							<a href="https://catenabible.com" target="_blank" rel="noopener noreferrer">About Us</a>
							<span class="link-divider">&bull;</span>
							<a href="https://forms.gle/utapMFsiTZZb1haFA" target="_blank" rel="noopener noreferrer">Share Feedback or Questions</a>
							<span class="link-divider">&bull;</span>
							<a href="https://forms.gle/KVeeDW41J9zqJtdZ7" target="_blank" rel="noopener noreferrer">Vote on Next Features</a>
						</div>

						<div class="footer-verses">
							<p class="footer-verse">"You search the Scriptures because you think that in them you have eternal life; and it is they that bear witness about me."<br/><span class="footer-ref">— John 5:39</span></p>
							<p class="footer-verse">"O you who have believed, do not ask about things which, if they are shown to you, would distress you"<br/><span class="footer-ref">— Quran: Surah Al-Ma'idah, Verse 101</span></p>
							<p class="footer-verse">"knowing this first of all, that no prophecy of Scripture comes from someone's own interpretation."<br/><span class="footer-ref">— 2 Peter 1:20</span></p>
							<p class="footer-verse">"So if you are in doubt about that which We have revealed to you, then ask those who have been reading the Scripture before you."<br/><span class="footer-ref">— Quran: Surah Yunus, Verse 94</span></p>
						</div>
					</footer>
				</main>

				<!-- Bottom Navigation (Hidden on desktop) -->
				<BottomNav client:load />
			</div>

			<!-- Global Onboarding Modal -->
			<OnboardingModal client:load />

			<!-- Collapsible Left Navigation Sidebar (Sitting on top of everything natively!) -->
			<div id="scripture-nav-overlay"></div>
			<div id="scripture-nav-sidebar">
				<ScriptureNav client:load />
			</div>

		</div>

		<!-- Navigation Toggles & Dynamic Scroll Header JS Script -->
		<script>
			const setupSidebarToggle = () => {
				const toggleBtn = document.getElementById('nav-toggle-btn');
				const sidebar = document.getElementById('scripture-nav-sidebar');
				const overlay = document.getElementById('scripture-nav-overlay');

				if (!toggleBtn || !sidebar || !overlay) return;

				const openSidebar = () => {
					sidebar.classList.add('open');
					overlay.classList.add('show');
					document.body.style.overflow = 'hidden';
				};

				const closeSidebar = () => {
					sidebar.classList.remove('open');
					overlay.classList.remove('show');
					document.body.style.overflow = '';
				};

				toggleBtn.addEventListener('click', openSidebar);
				overlay.addEventListener('click', closeSidebar);

				sidebar.addEventListener('click', (e) => {
					if (e.target instanceof HTMLElement && e.target.closest('a')) {
						closeSidebar();
					}
				});
			};

			let activeScrollHandler = null;
			let activeBrandClickHandler = null;

			const setupScrollHeader = () => {
				const headerBrand = document.getElementById('header-brand-text');
				const mainContent = document.querySelector('.main-content');
				const pageTitle = document.querySelector('.book-title') || document.querySelector('.verse-quote-box');

				if (activeScrollHandler && mainContent) {
					mainContent.removeEventListener('scroll', activeScrollHandler);
					activeScrollHandler = null;
				}
				if (activeBrandClickHandler && headerBrand) {
					headerBrand.removeEventListener('click', activeBrandClickHandler);
					activeBrandClickHandler = null;
				}

				if (!headerBrand || !mainContent || !pageTitle) return;

				const originalText = headerBrand.getAttribute('data-original') || '';

				const handleScroll = () => {
					const titleRect = pageTitle.getBoundingClientRect();
					if (titleRect.bottom < 52) {
						const docTitle = document.title.split('|')[0].trim();
						const cleanTitle = docTitle.replace('Evidence:', '🔍').trim();
						
						headerBrand.innerText = cleanTitle;
						headerBrand.classList.add('chapter-active');
					} else {
						headerBrand.innerText = originalText;
						headerBrand.classList.remove('chapter-active');
					}
				};

				mainContent.addEventListener('scroll', handleScroll);
				activeScrollHandler = handleScroll;
				
				const handleBrandClick = () => {
					if (headerBrand.classList.contains('chapter-active')) {
						mainContent.scrollTo({ top: 0, behavior: 'smooth' });
					}
				};
				headerBrand.addEventListener('click', handleBrandClick);
				activeBrandClickHandler = handleBrandClick;

				// Run once immediately to sync header state with initial scroll position
				handleScroll();
			};

			// Initialize layout components on page load/swap
			document.addEventListener('astro:page-load', () => {
				setupSidebarToggle();
				setupScrollHeader();
			});
			
			// Global resize listener (safe to add once since this module runs once)
			let resizeTimer;
			window.addEventListener('resize', () => {
				clearTimeout(resizeTimer);
				resizeTimer = setTimeout(setupSidebarToggle, 150);
			});

			// Global Loading Indicator for SPA progress bar
			document.addEventListener('astro:before-preparation', () => {
				const indicator = document.getElementById('global-loading-indicator');
				if (indicator) {
					indicator.classList.remove('done');
					indicator.classList.add('loading');
				}
			});
			document.addEventListener('astro:after-swap', () => {
				const indicator = document.getElementById('global-loading-indicator');
				if (indicator) {
					indicator.classList.remove('loading');
					indicator.classList.add('done');
				}
			});
		</script>
	</body>
</html>

<style is:global>
	/* ==========================================
	   CSS Design Tokens (Responsive Zinc Theme)
	   ========================================== */
	:root {
		--color-primary: #09090b; /* Zinc 950 */
		--color-on-primary: #ffffff;
		--color-secondary: #974543; /* Terracotta Red */
		--color-on-secondary: #ffffff;
		--color-background: #f4f4f5; /* Zinc 100 background */
		
		--color-surface: #ffffff;
		--color-on-surface: #09090b;
		--color-on-surface-variant: #71717a; /* Zinc 500 */
		--color-outline-variant: #e4e4e7; /* Zinc 200 */
		
		--color-surface-container-low: #f4f4f5;
		--color-surface-container-lowest: #ffffff;
		
		--color-primary-container: #e0e7ff; /* Indigo 100 */
		--color-on-primary-container: #3730a3; /* Indigo 800 */
		
		--color-secondary-container: #fce7f3; /* Pink 100 */
		--color-on-secondary-container: #9d174d; /* Pink 800 */
		
		--color-tertiary-container: #fef3c7; /* Amber 100 */
		--color-on-tertiary-container: #b45309; /* Amber 700 */
		
		--color-error-container: #fee2e2; /* Red 100 */
		--color-on-error-container: #b91c1c; /* Red 700 */
		
		--font-display: 'Literata', Georgia, 'Amiri', 'Traditional Arabic', Arial, serif;
		--font-body: 'Public Sans', -apple-system, 'Amiri', 'Traditional Arabic', Arial, sans-serif;
	}

	.theme-quran {
		--color-primary: #022c22;
		--color-secondary: #059669;
	}

	body {
		font-family: var(--font-body);
		margin: 0;
		padding: 0;
		box-sizing: border-box;
		background-color: #e4e4e7;
		overflow: hidden;
	}

	a {
		text-decoration: none;
		color: inherit;
	}

	/* ==========================================
	   Utility Classes
	   ========================================== */
	.select-none {
		user-select: none;
		-webkit-user-select: none;
	}
	
	.select-text {
		user-select: text;
		-webkit-user-select: text;
	}

	/* ==========================================
	   App Bounding Containers (Responsive Grid)
	   ========================================== */
	.app-container {
		width: 100%;
		max-width: 412px;
		height: 100vh;
		height: 100dvh;
		background-color: var(--color-surface);
		display: flex;
		flex-direction: column;
		position: relative;
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
		overflow: hidden;
		margin: 0 auto;
		transition: max-width 0.3s ease;
	}

	@media (min-width: 768px) {
		.app-container {
			max-width: 1100px;
			flex-direction: row;
			height: 92vh;
			border-radius: 20px;
		}
	}

	.content-frame {
		flex: 1;
		display: flex;
		flex-direction: column;
		height: 100%;
		position: relative;
		overflow: hidden;
	}

	.main-content {
		flex: 1;
		padding: 16px 16px 88px 16px;
		overflow-y: auto;
		background-color: var(--color-surface);
		-webkit-overflow-scrolling: touch;
	}
	@media (min-width: 768px) {
		.main-content {
			padding: 24px 32px;
		}
	}

	/* ==========================================
	   Header Layout & Dynamic Branding
	   ========================================== */
	.app-header {
		position: sticky;
		top: 0;
		z-index: 40;
		background-color: var(--color-surface);
		border-bottom: 1px solid var(--color-outline-variant);
		padding: 0 16px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		height: 52px;
		flex-shrink: 0;
	}
	@media (min-width: 768px) {
		.app-header {
			height: 56px;
		}
	}

	.header-left {
		display: flex;
		align-items: center;
		gap: 12px;
		min-width: 0;
		flex: 1;
	}

	.nav-burger-btn {
		padding: 6px;
		border-radius: 8px;
		border: none;
		background: none;
		color: var(--color-on-surface-variant);
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background-color 0.15s;
	}
	.nav-burger-btn:hover {
		background-color: var(--color-surface-container-low);
	}
	.nav-burger-btn svg {
		width: 20px;
		height: 20px;
		display: block;
	}
	@media (min-width: 768px) {
		.nav-burger-btn {
			display: none !important;
		}
	}

	.brand-container {
		display: flex;
		align-items: center;
		gap: 8px;
		user-select: none;
		min-width: 0;
		flex: 1;
	}

	.header-shield-logo {
		height: 26px !important;
		width: auto !important;
		display: block;
	}

	.brand-text {
		font-family: var(--font-body);
		font-weight: 800;
		font-size: 15px;
		letter-spacing: 0.3px;
		color: var(--color-primary);
		transition: color 0.25s cubic-bezier(0.4, 0, 0.2, 1);
		cursor: default;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	
	/* Morphing Active State */
	.brand-text.chapter-active {
		color: var(--color-secondary) !important; /* Indigo highlighted scroll target */
		cursor: pointer;
		font-family: var(--font-display); /* Fades into script font! */
		font-weight: 700;
		font-size: 16px;
	}
	.brand-text.chapter-active:hover {
		opacity: 0.75;
	}

	.header-right-spacer {
		width: 32px;
	}
	@media (min-width: 768px) {
		.header-right-spacer {
			display: none;
		}
	}

	/* ==========================================
	   Collapsible & Dockable Sidebar
	   ========================================== */
	#scripture-nav-sidebar {
		position: fixed;
		top: 0;
		bottom: 0;
		left: 0;
		width: 300px;
		z-index: 50;
		background-color: var(--color-surface);
		border-right: 1px solid var(--color-outline-variant);
		transform: translateX(-100%);
		transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
	}
	#scripture-nav-sidebar.open {
		transform: translateX(0);
	}

	@media (min-width: 768px) {
		#scripture-nav-sidebar {
			position: relative;
			transform: none !important;
			width: 280px;
			flex-shrink: 0;
			height: 100%;
			z-index: 30;
			order: -1; /* Dock on the left */
		}
	}

	#scripture-nav-overlay {
		position: fixed;
		inset: 0;
		background-color: rgba(9, 9, 11, 0.3);
		z-index: 40;
		display: none;
		opacity: 0;
		transition: opacity 0.2s ease;
	}
	#scripture-nav-overlay.show {
		display: block;
		opacity: 1;
	}
	@media (min-width: 768px) {
		#scripture-nav-overlay {
			display: none !important;
		}
	}

	/* ==========================================
	   Bottom Navigation Bar
	   ========================================== */
	.bottom-nav {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		height: 72px;
		background-color: var(--color-surface);
		border-top: 1px solid var(--color-outline-variant);
		display: flex;
		justify-content: space-around;
		align-items: center;
		z-index: 40;
		padding-bottom: env(safe-area-inset-bottom);
	}
	@media (min-width: 768px) {
		.bottom-nav {
			display: none !important;
		}
	}

	.nav-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		flex: 1;
		height: 100%;
		border: none;
		background: none;
		color: var(--color-on-surface-variant);
		cursor: pointer;
		font-size: 11px;
		font-weight: 700;
		transition: all 0.2s ease;
		position: relative;
	}

	.nav-icon-wrapper {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 52px;
		height: 28px;
		border-radius: 14px;
		margin-bottom: 3px;
		color: inherit;
		background-color: transparent;
		transition: all 0.2s ease;
	}
	.nav-icon-wrapper svg {
		width: 20px;
		height: 20px;
	}

	.nav-item:hover .nav-icon-wrapper {
		background-color: var(--color-surface-container-low);
	}

	.nav-item.active {
		color: var(--color-primary);
	}
	.nav-item.active .nav-icon-wrapper {
		background-color: #e4e4e7;
		color: #18181b;
	}

	.nav-item.disabled {
		opacity: 0.35;
		cursor: not-allowed;
	}

	.nav-item .badge {
		position: absolute;
		top: 6px;
		right: 12%;
		background-color: var(--color-surface-container-low);
		color: var(--color-on-surface-variant);
		font-size: 7px;
		font-weight: 800;
		padding: 1px 5px;
		border-radius: 99px;
		border: 1px solid var(--color-outline-variant);
		letter-spacing: 0.5px;
		text-transform: uppercase;
	}

	/* Scrollbar */
	::-webkit-scrollbar {
		width: 5px;
	}
	::-webkit-scrollbar-track {
		background: transparent;
	}
	::-webkit-scrollbar-thumb {
		background: var(--color-outline-variant);
		border-radius: 10px;
	}

	/* ==========================================
	   Footer
	   ========================================== */
	.app-footer {
		margin-top: 48px;
		padding-top: 24px;
		border-top: 1px solid var(--color-outline-variant);
		text-align: center;
		padding-bottom: 24px;
	}

	.footer-disclaimer {
		font-family: var(--font-body);
		font-size: 10px;
		color: var(--color-on-surface-variant);
		opacity: 0.5;
		max-width: 500px;
		margin: 0 auto 20px auto;
		line-height: 1.4;
		font-style: italic;
	}

	.footer-links {
		margin-bottom: 32px;
		font-family: var(--font-body);
		font-size: 11px;
		font-weight: 700;
		color: var(--color-on-surface-variant);
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		gap: 12px;
	}
	.footer-links a {
		color: var(--color-on-surface-variant);
		transition: color 0.15s;
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-color: rgba(113, 113, 122, 0.3);
	}
	.footer-links a:hover {
		color: var(--color-primary);
		text-decoration-color: var(--color-primary);
	}
	.link-divider {
		opacity: 0.5;
	}

	.footer-verses {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 24px 16px;
		max-width: 640px;
		margin: 0 auto;
		text-align: left;
	}

	.footer-verse {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 13px;
		color: var(--color-on-surface-variant);
		line-height: 1.6;
		margin: 0;
		opacity: 0.8;
	}

	.footer-ref {
		font-family: var(--font-body);
		font-style: normal;
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		display: block;
		margin-top: 4px;
		opacity: 0.6;
	}

	/* Global Loading Indicator (Progress Bar) */
	.global-loading-indicator {
		position: absolute;
		top: 0;
		left: 0;
		height: 3px;
		background-color: var(--color-secondary);
		z-index: 100;
		width: 0;
		opacity: 0;
		transition: width 0.4s ease, opacity 0.2s ease;
		pointer-events: none;
	}
	.global-loading-indicator.loading {
		opacity: 1;
		animation: simulate-loading 10s cubic-bezier(0.1, 0.8, 0.1, 1) forwards;
	}
	@keyframes simulate-loading {
		0% { width: 0%; }
		50% { width: 70%; }
		90% { width: 90%; }
		100% { width: 95%; }
	}
	.global-loading-indicator.done {
		width: 100% !important;
		opacity: 0;
