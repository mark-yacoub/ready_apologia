{
  "verses": [
    {
      "verse": 1,
      "quran_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ",
      "text": "The striking!",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 2,
      "quran_arabic": "مَا ٱلْقَارِعَةُ",
      "text": "What is the striking?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 3,
      "quran_arabic": "وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ",
      "text": "And what will make you know what the striking is?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 4,
      "quran_arabic": "يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ",
      "text": "The Day when the people will be like scattered moths,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 5,
      "quran_arabic": "وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ",
      "text": "and the mountains will be like (tufts of) wool.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 6,
      "quran_arabic": "فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ",
      "text": "As for the one whose scales are heavy,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 7,
      "quran_arabic": "فَهُوَ فِى عِيشَةٍۢ رَّاضِيَةٍۢ",
      "text": "he will be in a pleasing life,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 8,
      "quran_arabic": "وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ",
      "text": "but as for the one whose scales are light,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 9,
      "quran_arabic": "فَأُمُّهُۥ هَاوِيَةٌۭ",
      "text": "his mother will be Hāwiya.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 10,
      "quran_arabic": "وَمَآ أَدْرَىٰكَ مَا هِيَهْ",
      "text": "And what will make you know what she is?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 11,
      "quran_arabic": "نَارٌ حَامِيَةٌۢ",
      "text": "A scorching Fire!",
      "canonical_variants": [],
      "competing_variants": []
    }
  ]
}