{
  "verses": [
    {
      "verse": 1,
      "quran_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ",
      "text": "By the morning light!",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 2,
      "quran_arabic": "وَٱلَّيْلِ إِذَا سَجَىٰ",
      "text": "By the night when it darkens!",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 3,
      "quran_arabic": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
      "text": "Your Lord has not forsaken you, nor does He despise you.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 4,
      "quran_arabic": "وَلَلْءَاخِرَةُ خَيْرٌۭ لَّكَ مِنَ ٱلْأُولَىٰ",
      "text": "The last will indeed be better for you than the first.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 5,
      "quran_arabic": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ",
      "text": "Soon indeed your Lord will give to you, and you will be pleased.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 6,
      "quran_arabic": "أَلَمْ يَجِدْكَ يَتِيمًۭا فَـَٔاوَىٰ",
      "text": "Did He not find you an orphan and give (you) refuge?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 7,
      "quran_arabic": "وَوَجَدَكَ ضَآلًّۭا فَهَدَىٰ",
      "text": "Did He not find you astray and guide (you)?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 8,
      "quran_arabic": "وَوَجَدَكَ عَآئِلًۭا فَأَغْنَىٰ",
      "text": "Did He not find you poor and enrich (you)?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 9,
      "quran_arabic": "فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ",
      "text": "As for the orphan, do not oppress (him),",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 10,
      "quran_arabic": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ",
      "text": "and as for the beggar, do not repulse (him),",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 11,
      "quran_arabic": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ",
      "text": "and as for the blessing of your Lord, proclaim (it).",
      "canonical_variants": [],
      "competing_variants": []
    }
  ]
}