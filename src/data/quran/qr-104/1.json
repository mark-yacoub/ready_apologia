{
  "verses": [
    {
      "verse": 1,
      "quran_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَيْلٌۭ لِّكُلِّ هُمَزَةٍۢ لُّمَزَةٍ",
      "text": "Woe to every slanderer, fault finder,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 2,
      "quran_arabic": "ٱلَّذِى جَمَعَ مَالًۭا وَعَدَّدَهُۥ",
      "text": "who accumulates wealth and counts it over and over!",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 3,
      "quran_arabic": "يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ",
      "text": "He thinks that his wealth will make him last.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 4,
      "quran_arabic": "كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ",
      "text": "By no means! Indeed He will be tossed into al-Ḥuṭama.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 5,
      "quran_arabic": "وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ",
      "text": "And what will make you know what al-Ḥuṭama is?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 6,
      "quran_arabic": "نَارُ ٱللَّهِ ٱلْمُوقَدَةُ",
      "text": "The Fire of God ignited,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 7,
      "quran_arabic": "ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ",
      "text": "which rises up to the hearts.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 8,
      "quran_arabic": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌۭ",
      "text": "Surely it (will be) closed over them",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 9,
      "quran_arabic": "فِى عَمَدٍۢ مُّمَدَّدَةٍۭ",
      "text": "in extended columns (of flame).",
      "canonical_variants": [],
      "competing_variants": []
    }
  ]
}