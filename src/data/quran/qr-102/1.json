{
  "verses": [
    {
      "verse": 1,
      "quran_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلْهَىٰكُمُ ٱلتَّكَاثُرُ",
      "text": "Rivalry diverts you,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 2,
      "quran_arabic": "حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ",
      "text": "until you visit the graves.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 3,
      "quran_arabic": "كَلَّا سَوْفَ تَعْلَمُونَ",
      "text": "By no means! Soon you will know!",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 4,
      "quran_arabic": "ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ",
      "text": "Once again, by no means! Soon you will know!",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 5,
      "quran_arabic": "كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ",
      "text": "By no means! If (only) you knew (now) with the knowledge of certainty:",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 6,
      "quran_arabic": "لَتَرَوُنَّ ٱلْجَحِيمَ",
      "text": "you will indeed see the Furnace.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 7,
      "quran_arabic": "ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ",
      "text": "Once again, you will indeed see it with the eye of certainty.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 8,
      "quran_arabic": "ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ",
      "text": "Then, on that Day, you will indeed be asked about (what) bliss (is).",
      "canonical_variants": [],
      "competing_variants": []
    }
  ]
}