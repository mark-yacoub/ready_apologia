{
  "verses": [
    {
      "verse": 1,
      "quran_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ",
      "text": "Have you seen the one who calls the Judgment a lie?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 2,
      "quran_arabic": "فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ",
      "text": "That is the one who shoves away the orphan,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 3,
      "quran_arabic": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ",
      "text": "and does not urge (people) to the feeding of the poor.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 4,
      "quran_arabic": "فَوَيْلٌۭ لِّلْمُصَلِّينَ",
      "text": "Woe to the ones who pray,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 5,
      "quran_arabic": "ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ",
      "text": "who – they are heedless of their prayers,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 6,
      "quran_arabic": "ٱلَّذِينَ هُمْ يُرَآءُونَ",
      "text": "who – they (only) make a show,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 7,
      "quran_arabic": "وَيَمْنَعُونَ ٱلْمَاعُونَ",
      "text": "and withhold assistance!",
      "canonical_variants": [],
      "competing_variants": []
    }
  ]
}