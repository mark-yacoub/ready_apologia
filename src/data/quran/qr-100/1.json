{
  "verses": [
    {
      "verse": 1,
      "quran_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلْعَٰدِيَٰتِ ضَبْحًۭا",
      "text": "By the runners panting,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 2,
      "quran_arabic": "فَٱلْمُورِيَٰتِ قَدْحًۭا",
      "text": "and the strikers of fire,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 3,
      "quran_arabic": "فَٱلْمُغِيرَٰتِ صُبْحًۭا",
      "text": "and the chargers at dawn,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 4,
      "quran_arabic": "فَأَثَرْنَ بِهِۦ نَقْعًۭا",
      "text": "when they kick up a (cloud of) dust,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 5,
      "quran_arabic": "فَوَسَطْنَ بِهِۦ جَمْعًا",
      "text": "and pierce through the midst of it all together!",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 6,
      "quran_arabic": "إِنَّ ٱلْإِنسَٰنَ لِرَبِّهِۦ لَكَنُودٌۭ",
      "text": "Surely the human is indeed an ingrate to his Lord,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 7,
      "quran_arabic": "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌۭ",
      "text": "and surely he is indeed a witness to that,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 8,
      "quran_arabic": "وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ",
      "text": "and surely he is indeed harsh in (his) love for (worldly) goods.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 9,
      "quran_arabic": "۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ",
      "text": "Does he not know? When what is in the graves is ransacked,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 10,
      "quran_arabic": "وَحُصِّلَ مَا فِى ٱلصُّدُورِ",
      "text": "and what is in the hearts is extracted",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 11,
      "quran_arabic": "إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍۢ لَّخَبِيرٌۢ",
      "text": "– surely on that Day their Lord will indeed be aware of them.",
      "canonical_variants": [],
      "competing_variants": []
    }
  ]
}