{
  "verses": [
    {
      "verse": 1,
      "quran_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ",
      "text": "Did We not expand your heart for you,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 2,
      "quran_arabic": "وَوَضَعْنَا عَنكَ وِزْرَكَ",
      "text": "and deliver you of your burden,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 3,
      "quran_arabic": "ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ",
