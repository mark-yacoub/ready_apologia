{
  "verses": [
    {
      "verse": 1,
      "quran_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ",
      "text": "Recite in the name of your Lord who creates,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 2,
      "quran_arabic": "خَلَقَ ٱلْإِنسَٰنَ مِنْ عَلَقٍ",
      "text": "creates the human from a clot.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 3,
      "quran_arabic": "ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ",
      "text": "Recite, for your Lord is the Most Generous,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 4,
      "quran_arabic": "ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ",
      "text": "who teaches by the pen,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 5,
      "quran_arabic": "عَلَّمَ ٱلْإِنسَٰنَ مَا لَمْ يَعْلَمْ",
      "text": "teaches the human what he does not know.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 6,
      "quran_arabic": "كَلَّآ إِنَّ ٱلْإِنسَٰنَ لَيَطْغَىٰٓ",
      "text": "By no means! Surely the human transgresses insolently indeed,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 7,
      "quran_arabic": "أَن رَّءَاهُ ٱسْتَغْنَىٰٓ",
      "text": "for he considers himself independent.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 8,
      "quran_arabic": "إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ",
      "text": "Surely to your Lord is the return.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 9,
      "quran_arabic": "أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ",
      "text": "Have you seen the one who forbids",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 10,
      "quran_arabic": "عَبْدًا إِذَا صَلَّىٰٓ",
      "text": "a servant when he prays?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 11,
      "quran_arabic": "أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ",
      "text": "Have you seen whether he (relies) on the guidance,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 12,
      "quran_arabic": "أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ",
      "text": "or commands the guarding (of oneself)?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 13,
      "quran_arabic": "أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ",
      "text": "Have you seen whether he calls (it) a lie, and turns away?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 14,
      "quran_arabic": "أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ",
      "text": "Does he not know that God sees?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 15,
      "quran_arabic": "كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ",
      "text": "By no means! If indeed he does not stop, We shall indeed seize (him) by the hair –",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 16,
      "quran_arabic": "نَاصِيَةٍۢ كَٰذِبَةٍ خَاطِئَةٍۢ",
      "text": "(his) lying, sinful hair.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 17,
      "quran_arabic": "فَلْيَدْعُ نَادِيَهُۥ",
      "text": "So let him call his cohorts!",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 18,
      "quran_arabic": "سَنَدْعُ ٱلزَّبَانِيَةَ",
      "text": "We shall call the guards of Hell.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 19,
      "quran_arabic": "كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩",
      "text": "By no means! Do not obey him, but prostrate yourself and draw near.",
      "canonical_variants": [],
      "competing_variants": []
    }
  ]
}