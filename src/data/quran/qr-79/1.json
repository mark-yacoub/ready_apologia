    {
      "verse": 31,
      "quran_arabic": "أَخْرَجَ مِنْهَا مَآءَهَا وَمَرْعَىٰهَا",
      "text": "He brought forth from it its water and its pasture",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 32,
      "quran_arabic": "وَٱلْجِبَالَ أَرْسَىٰهَا",
      "text": "– and the mountains, He anchored it (to them) –",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 33,
      "quran_arabic": "مَتَٰعًۭا لَّكُمْ وَلِأَنْعَٰمِكُمْ",
      "text": "a provision for you and for your livestock.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 34,
      "quran_arabic": "فَإِذَا جَآءَتِ ٱلطَّآمَّةُ ٱلْكُبْرَىٰ",
      "text": "When the great overwhelming comes,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 35,
      "quran_arabic": "يَوْمَ يَتَذَكَّرُ ٱلْإِنسَٰنُ مَا سَعَىٰ",
      "text": "on the Day when a person will remember what he strove for,",
      "canonical_variants": [],
      "competing_variants": []
