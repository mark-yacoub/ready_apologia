    {
      "verse": 29,
      "quran_arabic": "وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَىٰهَا",
      "text": "He darkened its night and brought forth its morning light.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 30,
      "quran_arabic": "وَٱلْأَرْضَ بَعْدَ ذَٰلِكَ دَحَىٰهَآ",
      "text": "And the earth, after that, He spread it out.",
      "canonical_variants": [],
      "competing_variants": []
