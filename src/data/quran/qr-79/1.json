    {
      "verse": 43,
      "quran_arabic": "فِيمَ أَنتَ مِن ذِكْرَىٰهَآ",
      "text": "What do you have to do with the mention of it?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 44,
      "quran_arabic": "إِلَىٰ رَبِّكَ مُنتَهَىٰهَآ",
      "text": "To your Lord is its (ultimate) goal.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 45,
      "quran_arabic": "إِنَّمَآ أَنتَ مُنذِرُ مَن يَخْشَىٰهَا",
      "text": "You are only a warner for whoever fears it.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 46,
      "quran_arabic": "كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوٓا۟ إِلَّا عَشِيَّةً أَوْ ضُحَىٰهَا",
      "text": "On the Day when they see it, (it will seem) as if they had remained (in the grave) for only an evening or its morning light.",
