{
  "verses": [
    {
      "verse": 1,
      "quran_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ وَٱلنَّٰزِعَٰتِ غَرْقًۭا",
      "text": "By the ones who snatch violently!",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 2,
      "quran_arabic": "وَٱلنَّٰشِطَٰتِ نَشْطًۭا",
      "text": "By the ones who draw out completely!",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 3,
      "quran_arabic": "وَٱلسَّٰبِحَٰتِ سَبْحًۭا",
      "text": "By the ones who glide smoothly,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 4,
      "quran_arabic": "فَٱلسَّٰبِقَٰتِ سَبْقًۭا",
      "text": "and race swiftly,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 5,
      "quran_arabic": "فَٱلْمُدَبِّرَٰتِ أَمْرًۭا",
      "text": "and direct the affair!",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 6,
      "quran_arabic": "يَوْمَ تَرْجُفُ ٱلرَّاجِفَةُ",
      "text": "On the Day when the (earth)quake quakes,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 7,
      "quran_arabic": "تَتْبَعُهَا ٱلرَّادِفَةُ",
      "text": "and that which ensues follows it,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 8,
      "quran_arabic": "قُلُوبٌۭ يَوْمَئِذٍۢ وَاجِفَةٌ",
      "text": "hearts on that Day will pound,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 9,
      "quran_arabic": "أَبْصَٰرُهَا خَٰشِعَةٌۭ",
      "text": "their sight downcast.",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 10,
      "quran_arabic": "يَقُولُونَ أَءِنَّا لَمَرْدُودُونَ فِى ٱلْحَافِرَةِ",
      "text": "They will say, ‘Are we indeed being turned back into (our) former state?",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 11,
      "quran_arabic": "أَءِذَا كُنَّا عِظَٰمًۭا نَّخِرَةًۭ",
