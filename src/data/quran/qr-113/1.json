{
  "verses": [
    {
      "verse": 1,
      "quran_arabic": "بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ ٱلْفَلَقِ",
      "text": "Say: ‘I take refuge with the Lord of the daybreak,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 2,
      "quran_arabic": "مِن شَرِّ مَا خَلَقَ",
      "text": "from the evil of what He has created,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 3,
      "quran_arabic": "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ",
      "text": "and from the evil of darkness when it looms,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 4,
      "quran_arabic": "وَمِن شَرِّ ٱلنَّفَّٰثَٰتِ فِى ٱلْعُقَدِ",
      "text": "and from the evil of the women who blow on knots,",
      "canonical_variants": [],
      "competing_variants": []
    },
    {
      "verse": 5,
      "quran_arabic": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ",
      "text": "and from the evil of an envier when he envies.’",
      "canonical_variants": [],
      "competing_variants": []
    }
  ]
}