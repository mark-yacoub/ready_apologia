---
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const site = Astro.site ? Astro.site.toString().replace(/\/$/, '') : '';
const redirectUrl = `${base}/bible/jn/1`;
const canonicalUrl = new URL(redirectUrl, Astro.site || Astro.url).href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Ready Apologia - Christian Apologetics & Scripture Evidence</title>

  <!-- SEO & Open Graph Tags for Root URL Sharing -->
  <meta name="description" content="Explore the core theology and scripture of Christianity and Islam, directly using verses from the scripture and ancient writers' quotes. Examine ancient manuscript evidence, responses to alleged contradictions, Patristic and modern apologetics." />
  <meta name="keywords" content="christian apologetics, bible interlinear, scripture evidence, defend the faith, manuscript evidence, early church fathers, quranic analysis" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Ready Apologia - Christian Apologetics & Scripture Evidence" />
  <meta property="og:description" content="Explore the core theology and scripture of Christianity and Islam, directly using verses from the scripture and ancient writers' quotes. Examine ancient manuscript evidence, responses to alleged contradictions, Patristic and modern apologetics." />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={`${site}${base}/default-og-image.png`} />

  <link rel="canonical" href={canonicalUrl} />
  <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />
  <script is:inline define:vars={{ defaultRedirectUrl: redirectUrl }}>
    const lastVisitedUrl = localStorage.getItem('lastVisitedUrl');
    if (lastVisitedUrl) {
      window.location.replace(lastVisitedUrl);
    } else {
      window.location.replace(defaultRedirectUrl);
    }
  </script>
</head>
<body style="margin: 0; padding: 0; background-color: #f8fafc;">
</body>
</html>
