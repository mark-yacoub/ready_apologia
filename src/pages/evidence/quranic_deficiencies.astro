---
import Layout from '../../layouts/Layout.astro';
import QuranicEvidenceExplorer from '../../components/QuranicEvidenceExplorer.jsx';
import verseLabelsObj from '../../data/quran/verse_labels.json';
import drogeTranslation from '../../data/quran/english/droge_translation.json';
import { loadAllEvidenceData } from '../../utils/evidenceLoader.js';

// We load all evidence solely to populate the generic top-of-page Dropdown selector,
// so users can still switch from "Quranic Deficiencies" back to "Divinity of Christ".
const evidenceDropdownData = loadAllEvidenceData();
const evidenceTitle = "Quranic Deficiencies & Evidence";
const evidenceDesc = "Analyzing theological and historical deficiencies in the Quran via direct scripture evidence.";
---

<Layout title={evidenceTitle} description={evidenceDesc} theme="quran">
  <div class="evidence-page-container">
    <QuranicEvidenceExplorer 
      client:load 
      evidenceDropdownData={evidenceDropdownData} 
      verseLabels={verseLabelsObj} 
      drogeTranslation={drogeTranslation} 
    />
  </div>
</Layout>

<style>
  .evidence-page-container {
    display: flex;
    flex-direction: column;
    padding-top: 12px;
    min-height: 100%;
  }
</style>
