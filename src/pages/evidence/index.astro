---
import Layout from '../../layouts/Layout.astro';
import EvidenceExplorer from '../../components/EvidenceExplorer.jsx';
import { loadAllEvidenceData } from '../../utils/evidenceLoader.js';

const evidenceData = loadAllEvidenceData();

const pageDesc = "Explore the core theology and scripture of Christianity and Islam, directly using verses from the scripture or ancient writers' quotes.";
const pageKeywords = "apologetics directory, christian evidence, defend the faith, scriptural apologetics, early church theology";

const schemaObj = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "headline": "Christian Apologetics Evidence & Scripture Evidence",
  "description": pageDesc,
  "hasPart": evidenceData.map(t => ({
    "@type": "WebPage",
    "name": t.evidenceId.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()),
    "url": `${Astro.url.origin}${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/evidence/${t.evidenceId}`
  }))
};
const schemaJson = JSON.stringify(schemaObj);
---

<Layout title="Christian Apologetics Evidence Directory" description={pageDesc} keywords={pageKeywords} schema={schemaJson}>
  <div class="evidence-index-container">
    <EvidenceExplorer client:load evidence={evidenceData} />
  </div>
</Layout>

<style>
  .evidence-index-container {
    display: flex;
    flex-direction: column;
    padding-top: 12px;
  }
</style>
