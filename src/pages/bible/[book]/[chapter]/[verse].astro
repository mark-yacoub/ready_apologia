---
import { query } from '../../../../db.js';
import booksMeta from '../../../../data/books_meta.json';

// Pre-render the base verse redirect gates (Genesis & John throttled for dev speed)
export async function getStaticPaths() {
  const ms = query("SELECT DISTINCT verse_id FROM manuscript_per_verse").map(r => r.verse_id);
  const ct = query("SELECT DISTINCT verse1 as v FROM contradictions UNION SELECT DISTINCT verse2 FROM contradictions").map(r => r.v);
  const ap = query("SELECT DISTINCT verse FROM apologetics").map(r => r.verse);
  
  const allVerseIds = new Set([...ms, ...ct, ...ap].filter(Boolean));
  const paths = [];
  const devActiveBooks = ['jn', 'gn'];

  allVerseIds.forEach(id => {
    const parts = id.split('_');
    if (parts.length === 3 && devActiveBooks.includes(parts[0])) {
      paths.push({
        params: {
          book: parts[0],
          chapter: parts[1],
          verse: parts[2]
        }
      });
    }
  });

  return paths;
}

const { book, chapter, verse } = Astro.params;
const verseId = `${book}_${chapter}_${verse}`;

// Query SQLite to check what active evidence types exist for this verse ID, in order of priority
const hasMs = query("SELECT 1 FROM manuscript_per_verse WHERE verse_id = :verseId LIMIT 1", { verseId }).length > 0;
const hasCt = query("SELECT 1 FROM contradictions WHERE verse1 = :verseId OR verse2 = :verseId LIMIT 1", { verseId }).length > 0;
const hasAp = query("SELECT 1 FROM apologetics WHERE verse = :verseId LIMIT 1", { verseId }).length > 0;

// Determine the first active evidence tab target
let firstTab = 'manuscripts';
if (hasMs) {
  firstTab = 'manuscripts';
} else if (hasCt) {
  firstTab = 'contradictions';
} else if (hasAp) {
  firstTab = 'apologetics';
}

const redirectUrl = `/bible/${book}/${chapter}/${verse}/${firstTab}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Redirecting...</title>
  <!-- Instant offline-safe meta refresh to sub-path active tab -->
  <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />
  <script is:inline define:vars={{ redirectUrl }}>
    // Dynamic instant fallback redirect
    window.location.replace(redirectUrl);
  </script>
</head>
<body style="background-color: #f8fafc; font-family: sans-serif; text-align: center; padding-top: 100px; color: #64748b;">
  <p>Redirecting you to verse evidence details...</p>
  <a href={redirectUrl} style="color: #974543; font-weight: bold; text-decoration: none;">Click here if you are not redirected</a>
</body>
</html>
