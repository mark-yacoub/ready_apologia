---
import { query } from '../../../../db.js';
import booksMeta from '../../../../data/books_meta.json';
import { mapLxxToMt } from '../../../../utils/scripture_mapper.js';
import { BUILD_BOOKS } from '../../../../utils/build_config.js';
import { getAllEvidenceVerseSets, parseVerseId } from '../../../../utils/path_generator.js';

// Pre-render the base verse redirect gates
export async function getStaticPaths() {
  const { allVerseIds } = getAllEvidenceVerseSets();
  const paths = [];

  allVerseIds.forEach(id => {
    const parts = parseVerseId(id);
    if (parts) {
      paths.push({
        params: {
          book: parts.book,
          chapter: parts.chapter,
          verse: parts.verse
        }
      });
    }
  });

  return BUILD_BOOKS ? paths.filter(p => BUILD_BOOKS.has(p.params.book)) : paths;
}

const { book, chapter, verse } = Astro.params;
const lxxId = `${book}_${chapter}_${verse}`;
const isNT = booksMeta.nt.some(b => b.id === book);
const mtObj = mapLxxToMt(book, chapter, verse);
const mtId = `${mtObj.book}_${mtObj.chapter}_${mtObj.verse}`;
const checkId = isNT ? lxxId : mtId;

// Query SQLite to check what active evidence types exist for this verse ID, in order of priority
const hasMs = isNT
  ? query("SELECT 1 FROM manuscript_per_verse WHERE verse_id = :lxxId LIMIT 1", { lxxId }).length > 0
  : query("SELECT 1 FROM manuscript_per_verse_ot WHERE (verse_id = :lxxId AND v11n_type = 'LXX') OR (verse_id = :mtId AND v11n_type = 'MT') LIMIT 1", { lxxId, mtId }).length > 0;

const hasCt = query("SELECT 1 FROM contradictions WHERE verse1 = :checkId OR verse2 = :checkId LIMIT 1", { checkId }).length > 0;
const hasAp = query("SELECT 1 FROM apologetics WHERE verse = :checkId LIMIT 1", { checkId }).length > 0;
const hasVd = query("SELECT 1 FROM short_per_verse WHERE verse_id = :checkId LIMIT 1", { checkId }).length > 0;

// Determine the first active evidence tab target
let firstTab = 'manuscripts';
if (hasMs) {
  firstTab = 'manuscripts';
} else if (hasCt) {
  firstTab = 'contradictions';
} else if (hasAp) {
  firstTab = 'apologetics';
} else if (hasVd) {
  firstTab = 'videos';
}

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
const redirectUrl = `${base}/bible/${book}/${chapter}/${verse}/${firstTab}`;
const canonicalUrl = new URL(redirectUrl, Astro.site || Astro.url).href;

return Astro.redirect(encodeURI(redirectUrl), 301);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Ready Apologia</title>
  <link rel="canonical" href={canonicalUrl} />
  <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />
  <script is:inline define:vars={{ redirectUrl }}>
    window.location.replace(redirectUrl);
  </script>
</head>
<body style="margin: 0; padding: 0; background-color: #f8fafc;">
</body>
</html>
