---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../../../../layouts/Layout.astro';
import VerseTabs from '../../../../../components/VerseTabs.jsx';
import ManuscriptCarousel from '../../../../../components/ManuscriptCarousel.jsx';
import { query } from '../../../../../db.js';
import booksMeta from '../../../../../data/books_meta.json';
import { parseMarkdown } from '../../../../../utils/markdown.js';

// 1. Pre-render sub-path page routes only for active evidence tabs (Throttled to Genesis/John for rapid dev speed)
export async function getStaticPaths() {
  const ms = query("SELECT DISTINCT verse_id FROM manuscript_per_verse").map(r => r.verse_id);
  const ct = query("SELECT DISTINCT verse1 as v FROM contradictions UNION SELECT DISTINCT verse2 FROM contradictions").map(r => r.v);
  const ap = query("SELECT DISTINCT verse FROM apologetics").map(r => r.verse);
  
  const allVerseIds = new Set([...ms, ...ct, ...ap].filter(Boolean));
  const paths = [];

  allVerseIds.forEach(id => {
    const parts = id.split('_');
    if (parts.length === 3) {
      const b = parts[0];
      const c = parts[1];
      const v = parts[2];
      
      // Check what evidence types actually exist in SQLite for this specific verse ID
      const hasMs = query("SELECT 1 FROM manuscript_per_verse WHERE verse_id = :id LIMIT 1", { id }).length > 0;
      const hasCt = query("SELECT 1 FROM contradictions WHERE verse1 = :id OR verse2 = :id LIMIT 1", { id }).length > 0;
      const hasAp = query("SELECT 1 FROM apologetics WHERE verse = :id LIMIT 1", { id }).length > 0;
      
      // Generate ONLY the valid sub-path routes!
      if (hasMs) paths.push({ params: { book: b, chapter: c, verse: v, tab: 'manuscripts' } });
      if (hasCt) paths.push({ params: { book: b, chapter: c, verse: v, tab: 'contradictions' } });
      if (hasAp) paths.push({ params: { book: b, chapter: c, verse: v, tab: 'apologetics' } });
    }
  });

  return paths;
}

const { book, chapter, verse, tab } = Astro.params;
const verseId = `${book}_${chapter}_${verse}`;

// 2. Find Book Details
const isNT = booksMeta.nt.some(b => b.id === book);
const bookMeta = isNT 
  ? booksMeta.nt.find(b => b.id === book)
  : booksMeta.ot.find(b => b.id === book);

if (!bookMeta) {
  return Astro.redirect('/404');
}

// 3. Query active evidence counts (natively in SQLite!)
const msCount = query("SELECT COUNT(DISTINCT image_name) as count FROM manuscript_per_verse WHERE verse_id = :verseId", { verseId })[0].count;
const ctCount = query("SELECT COUNT(DISTINCT title) as count FROM contradictions WHERE verse1 = :verseId OR verse2 = :verseId", { verseId })[0].count;
const apCount = query("SELECT COUNT(DISTINCT title) as count FROM apologetics WHERE verse = :verseId", { verseId })[0].count;

// 4. Query active evidence data
let manuscripts = [];
let contradictions = [];
let apologetics = [];

if (tab === 'manuscripts') {
  const rawManuscripts = query(`
    SELECT m.image_name, mm.* 
    FROM manuscript_per_verse m 
    LEFT JOIN manuscripts_meta mm ON m.ms_id = mm.ms_id 
    WHERE m.verse_id = :verseId
    ORDER BY mm.earliest_date ASC
  `, { verseId });

  // Automatic Page/Scan Indexing (Prevents duplicates confusion for P66, etc.)
  const msCounts = {};
  rawManuscripts.forEach(ms => {
    if (ms.ms_id) {
      msCounts[ms.ms_id] = (msCounts[ms.ms_id] || 0) + 1;
    }
  });

  const msTracker = {};
  manuscripts = rawManuscripts.map(ms => {
    const total = msCounts[ms.ms_id] || 0;
    let displayName = ms.name || ms.ms_id;
    
    if (total > 1) {
      msTracker[ms.ms_id] = (msTracker[ms.ms_id] || 0) + 1;
      displayName = `${ms.name || ms.ms_id} (Scan ${msTracker[ms.ms_id]})`;
    }
    
    return {
      ...ms,
      name: displayName
    };
  });
}

if (tab === 'contradictions') {
  contradictions = query(`
    SELECT c.*, m.name as meta_name, m.url as meta_url, m.copyright as meta_copyright
    FROM contradictions c
    LEFT JOIN apologetics_meta m ON c.src = m.id
    WHERE c.verse1 = :verseId OR c.verse2 = :verseId
    GROUP BY c.title
  `, { verseId });
}

if (tab === 'apologetics') {
  apologetics = query(`
    SELECT a.*, m.name as meta_name, m.url as meta_url, m.copyright as meta_copyright
    FROM apologetics a
    LEFT JOIN apologetics_meta m ON a.src = m.id
    WHERE a.verse = :verseId
    GROUP BY a.title
  `, { verseId });
}

function formatBookIdToName(id) {
  if (!id) return '';
  const bookCode = id.split('_')[0];
  const found = booksMeta.nt.find(b => b.id === bookCode) || booksMeta.ot.find(b => b.id === bookCode);
  return found ? found.name : bookCode.toUpperCase();
}

function formatVerseIdToLabel(id) {
  if (!id) return '';
  const parts = id.split('_');
  return `${formatBookIdToName(id)} ${parts[1]}:${parts[2]}`;
}

function formatVerseIdToLink(id) {
  if (!id) return '';
  const parts = id.split('_');
  return `/bible/${parts[0]}/${parts[1]}/${parts[2]}/contradictions`; // Route contrast link directly to its contradictions sub-path!
}
---

<Layout title={`Evidence: ${bookMeta.name} ${chapter}:${verse}`}>
  <div class="verse-detail-container">
    
    <!-- Top Header Back Navigation -->
    <header class="detail-header select-none">
      <a href={`/bible/${book}/${chapter}`} class="back-btn" aria-label="Go back to chapter reader">
        <span class="back-arrow">
          <svg width="6" height="10" fill="none" stroke="currentColor" viewBox="0 0 6 10" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 9L1 5l4-4" />
          </svg>
        </span>
        <span>{bookMeta.name} {chapter}</span>
      </a>
      
      <!-- Minimalist Heading showing exactly John 1:1 -->
      <h2 class="verse-drawer-title">
        {bookMeta.name} {chapter}:{verse}
      </h2>
    </header>

    <!-- Static Segmented Tab switcher anchors -->
    <VerseTabs 
      client:load 
      msCount={msCount}
      ctCount={ctCount}
      apCount={apCount}
      activeTab={tab}
      book={book}
      chapter={chapter}
      verse={verse}
    >
      
      <!-- ACTIVE TAB PANEL CONTENTS -->
      
      {tab === 'manuscripts' && (
        <div slot="manuscripts">
          <ManuscriptCarousel 
            client:load 
            manuscripts={manuscripts} 
            verseId={verseId} 
            verseLabel={`${bookMeta.name} ${chapter}:${verse}`} 
          />
        </div>
      )}

      {tab === 'contradictions' && (
        <div slot="contradictions" class="contradiction-panel-container">
          {contradictions.length > 0 ? (
            contradictions.map((ct, index) => {
              const otherVerseId = ct.verse1 === verseId ? ct.verse2 : ct.verse1;
              const otherVerseLabel = formatVerseIdToLabel(otherVerseId);
              const otherVerseLink = formatVerseIdToLink(otherVerseId);
              
              // Determine if details panel is open by default (always open if 1, pre-open 1st if multiple)
              const isInitiallyOpen = contradictions.length === 1 || index === 0;
              
              return (
                <details open={isInitiallyOpen} class="contradiction-details-card">
                  
                  {/* Interactive Accordion Header Title */}
                  <summary class="contradiction-summary-header select-none">
                    <span class="summary-title">{ct.title}</span>
                    <span class="summary-chevron">
                      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                      </svg>
                    </span>
                  </summary>

                  {/* Collapsible Content Panel */}
                  <div class="contradiction-card-content">
                    
                    {otherVerseId && (
                      <div class="contrasting-badge-box select-none">
                        <span class="badge-box-label">Contrasting Link:</span>
                        <a href={otherVerseLink} class="contrasting-link-pill">
                          <span>{otherVerseLabel}</span>
                          <span class="link-arrow">&rarr;</span>
                        </a>
                      </div>
                    )}

                    {/* Rich Markdown body parser */}
                    <div class="card-response-body select-text">
                      <div set:html={parseMarkdown(ct.answer)} />
                    </div>
                    
                    {/* Subtle Source Meta Credit Footer */}
                    <div class="card-footer-source-box select-none">
                      <div class="source-meta-text">
                        <span class="source-meta-label">Source:</span>
                        <span class="source-name-text">{ct.meta_name || ct.src}</span>
                        {ct.meta_copyright && <span class="source-copyright-text">({ct.meta_copyright})</span>}
                      </div>
                      {ct.meta_url && (
                        <a href={ct.meta_url} target="_blank" rel="noopener noreferrer" class="source-visit-pill-btn" title="Visit website page source">
                          <span>Visit Source</span>
                          <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </a>
                      )}
                    </div>

                  </div>

                </details>
              );
            })
          ) : (
            <p class="empty-tabs-placeholder">No alleged contradictions mapped for this verse.</p>
          )}
        </div>
      )}

      {tab === 'apologetics' && (
        <div slot="apologetics" class="apologetics-panel-container">
          {apologetics.length > 0 ? (
            apologetics.map((ap, index) => {
              // Determine if details panel is open by default (always open if 1, pre-open 1st if multiple)
              const isInitiallyOpen = apologetics.length === 1 || index === 0;
              
              return (
                <details open={isInitiallyOpen} class="apologetics-details-card">
                  
                  {/* Interactive Accordion Header Title */}
                  <summary class="apologetics-summary-header select-none">
                    <span class="summary-title">{ap.title}</span>
                    <span class="summary-chevron">
                      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                      </svg>
                    </span>
                  </summary>

                  {/* Collapsible Content Panel */}
                  <div class="apologetics-card-content">
                    
                    {/* Rich Markdown body parser */}
                    <div class="card-response-body select-text">
                      <div set:html={parseMarkdown(ap.answer)} />
                    </div>
                    
                    {/* Subtle Source Meta Credit Footer */}
                    <div class="card-footer-source-box select-none">
                      <div class="source-meta-text">
                        <span class="source-meta-label">Source:</span>
                        <span class="source-name-text">{ap.meta_name || ap.src}</span>
                        {ap.meta_copyright && <span class="source-copyright-text">({ap.meta_copyright})</span>}
                      </div>
                      {ap.meta_url && (
                        <a href={ap.meta_url} target="_blank" rel="noopener noreferrer" class="source-visit-pill-btn" title="Visit website page source">
                          <span>Visit Source</span>
                          <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </a>
                      )}
                    </div>

                  </div>

                </details>
              );
            })
          ) : (
            <p class="empty-tabs-placeholder">No apologetics defenses mapped for this verse.</p>
          )}
        </div>
      )}

    </VerseTabs>
  </div>
</Layout>

<style>
	/* ==========================================
	   Tab Sub-Path Detail View CSS
	   ========================================== */
	.verse-detail-container {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	/* Header Apple Navigation */
	.detail-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-bottom: 1px solid var(--color-outline-variant);
		padding-bottom: 14px;
	}

	.back-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 12px;
		background-color: var(--color-surface-container-low);
		color: var(--color-on-surface-variant);
		border: 1px solid var(--color-outline-variant);
		border-radius: 8px;
		font-size: 11px;
		font-weight: 700;
		text-decoration: none;
		transition: all 0.15s ease;
	}
	.back-btn:hover {
		background-color: var(--color-outline-variant);
		color: var(--color-primary);
	}
	.back-btn:active {
		transform: scale(0.97);
	}
	.back-arrow {
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.back-arrow svg {
		stroke: currentColor;
		fill: none;
	}

	.verse-drawer-title {
		font-family: var(--font-display);
		font-size: 22px;
		font-weight: 800;
		color: var(--color-primary);
		margin: 0;
		letter-spacing: -0.01em;
	}

	/* Panels */
	.contradiction-panel-container, .apologetics-panel-container {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	/* Semantic Details/Summary Accordion Cards */
	.contradiction-details-card {
		background-color: var(--color-surface);
		border: 1px solid var(--color-outline-variant);
		border-left: 3px solid transparent; /* Keep left border consistent for alignment */
		border-radius: 14px;
		overflow: hidden;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
		transition: all 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
		display: flex;
		flex-direction: column;
	}
	.contradiction-details-card:hover {
		transform: translateY(-1.5px);
		box-shadow: 0 8px 12px -2px rgba(0, 0, 0, 0.03);
		border-color: var(--color-outline);
	}
	.contradiction-details-card[open] {
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04);
		border-color: rgba(151, 69, 67, 0.25);
		border-left: 3px solid var(--color-secondary); /* 3px terracotta edge accent indicators! */
	}

	.contradiction-summary-header {
		padding: 16px;
		cursor: pointer;
		font-family: var(--font-body);
		font-size: 15px;
		font-weight: 800;
		color: var(--color-primary);
		list-style: none; /* Hide default disclosure arrow */
		display: flex;
		justify-content: space-between;
		align-items: center;
		transition: background-color 0.15s;
	}
	.contradiction-summary-header::-webkit-details-marker {
		display: none; /* Safari support */
	}
	.contradiction-summary-header:hover {
		background-color: #f9f8f7; /* Soft warm sandstone-cream on hover! */
	}

	.summary-title {
		flex: 1;
		line-height: 1.35;
		padding-right: 10px;
	}

	.summary-chevron {
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-on-surface-variant);
		transition: transform 0.2s ease;
	}
	.contradiction-details-card[open] .summary-chevron {
		transform: rotate(180deg);
		color: var(--color-secondary);
	}

	.contradiction-card-content {
		padding: 16px;
		display: flex;
		flex-direction: column;
		gap: 12px;
		border-top: 1px solid var(--color-outline-variant);
		animation: slideDown 0.3s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
	}

	/* ==========================================
	   Apologetics Accordion Specific Rules (Blue Theme)
	   ========================================== */
	.apologetics-details-card {
		background-color: var(--color-surface);
		border: 1px solid var(--color-outline-variant);
		border-left: 3px solid transparent;
		border-radius: 14px;
		overflow: hidden;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
		transition: all 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
		display: flex;
		flex-direction: column;
	}
	.apologetics-details-card:hover {
		transform: translateY(-1.5px);
		box-shadow: 0 8px 12px -2px rgba(0, 0, 0, 0.03);
		border-color: var(--color-outline);
	}
	.apologetics-details-card[open] {
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04);
		border-color: rgba(37, 99, 235, 0.25); /* 25% blue border */
		border-left: 3px solid #2563eb; /* 3px Apple Blue edge accent indicator! */
	}

	.apologetics-summary-header {
		padding: 16px;
		cursor: pointer;
		font-family: var(--font-body);
		font-size: 15px;
		font-weight: 800;
		color: var(--color-primary);
		list-style: none;
		display: flex;
		justify-content: space-between;
		align-items: center;
		transition: background-color 0.15s;
	}
	.apologetics-summary-header::-webkit-details-marker {
		display: none;
	}
	.apologetics-summary-header:hover {
		background-color: #f9f8f7; /* soft warm sandstone hover */
	}

	.apologetics-details-card[open] .summary-chevron {
		transform: rotate(180deg);
		color: #2563eb; /* Rotate chevron into Apple Blue! */
	}

	.apologetics-card-content {
		padding: 16px;
		display: flex;
		flex-direction: column;
		gap: 12px;
		border-top: 1px solid var(--color-outline-variant);
		animation: slideDown 0.3s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
	}

	/* Source Meta Credit Footer Layouts */
	.card-footer-source-box {
		display: flex;
		align-items: center;
		justify-content: space-between;
		border-top: 1px dashed var(--color-outline-variant);
		padding-top: 10px;
		margin-top: 4px;
	}
	.source-meta-text {
		font-size: 10px;
		color: var(--color-on-surface-variant);
		opacity: 0.95;
	}
	.source-meta-label {
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.3px;
		margin-right: 4px;
	}
	.source-name-text {
		font-weight: 700;
	}
	.source-copyright-text {
		font-style: italic;
		margin-left: 4px;
		opacity: 0.85;
	}

	.source-visit-pill-btn {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		padding: 3px 8px;
		border-radius: 5px;
		background-color: var(--color-surface-container-low);
		border: 1px solid var(--color-outline-variant);
		color: var(--color-primary);
		font-size: 10px;
		font-weight: 800;
		text-decoration: none;
		transition: all 0.15s;
	}
	.source-visit-pill-btn:hover {
		background-color: var(--color-outline-variant);
		color: var(--color-secondary);
	}
	.source-visit-pill-btn svg {
		stroke: currentColor;
		fill: none;
	}

	/* Markdown Inline Links Styling */
	.card-response-body :global(.exegesis-inline-link) {
		color: var(--color-secondary) !important;
		font-weight: 700;
		text-decoration: none;
		border-bottom: 1px dashed var(--color-secondary);
		transition: border-bottom-color 0.15s;
	}
	.card-response-body :global(.exegesis-inline-link:hover) {
		border-bottom-style: solid;
	}

	/* Markdown Standalone horizontal dividers */
	.card-response-body :global(.exegesis-divider) {
		border: none;
		border-top: 1px solid var(--color-outline-variant);
		margin: 10px 0;
		width: 100%;
		opacity: 0.5;
	}

	/* Inline Scripture Reference Badges style */
	.card-response-body :global(.exegesis-scripture-pill) {
		display: inline-flex;
		align-items: center;
		background-color: var(--color-surface-container-low);
		border: 1px solid var(--color-outline-variant);
		color: var(--color-primary);
		font-family: var(--font-body);
		font-size: 11px;
		font-weight: 800;
		padding: 2.5px 6px;
		border-radius: 5px;
		margin: 0 3px;
		vertical-align: middle;
		user-select: none;
		letter-spacing: -0.01em;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.01);
	}

	@keyframes slideDown {
		from { opacity: 0; transform: translateY(-2px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.card-header {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		padding: 3px 7px;
		border-radius: 5px;
		font-size: 9.5px;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		align-self: flex-start;
	}
	.card-icon {
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.card-icon svg {
		stroke: currentColor;
		fill: none;
	}

	.red-badge {
		background-color: rgba(151, 69, 67, 0.05);
		color: var(--color-secondary);
		border: 1px solid rgba(151, 69, 67, 0.2);
	}
	.blue-badge {
		background-color: rgba(37, 99, 235, 0.05);
		color: #2563eb;
		border: 1px solid rgba(37, 99, 235, 0.2);
	}

	.card-title {
		font-family: var(--font-body);
		font-size: 16px;
		font-weight: 800;
		color: var(--color-primary);
		margin: 0;
		line-height: 1.3;
	}

	/* Contrasting Cross-Reference Link Pill */
	.contrasting-badge-box {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 8px 10px;
		background-color: #fafafa;
		border: 1px solid var(--color-outline-variant);
		border-radius: 8px;
	}
	.badge-box-label {
		font-size: 10px;
		font-weight: 700;
		color: var(--color-on-surface-variant);
	}
	.contrasting-link-pill {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		padding: 3px 8px;
		border-radius: 5px;
		background-color: rgba(151, 69, 67, 0.08);
		border: 1px solid rgba(151, 69, 67, 0.2);
		color: var(--color-secondary);
		font-size: 11px;
		font-weight: 800;
		text-decoration: none;
		transition: background-color 0.15s;
	}
	.contrasting-link-pill:hover {
		background-color: rgba(151, 69, 67, 0.15);
	}
	.link-arrow {
		font-size: 10px;
	}

	/* Exegesis response body styling */
	.card-response-body {
		border-top: 1px solid var(--color-outline-variant);
		padding-top: 10px;
		display: flex;
		flex-direction: column;
		gap: 6px;
	}

	.body-section-label {
		font-size: 9.5px;
		font-weight: 800;
		color: var(--color-primary);
		text-transform: uppercase;
		letter-spacing: 0.5px;
