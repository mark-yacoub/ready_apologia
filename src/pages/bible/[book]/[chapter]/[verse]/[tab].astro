---
import { generateBibleTabSEO } from '../../../../../utils/seoFactory.js';
import Layout from '../../../../../layouts/Layout.astro';
import VerseTabs from '../../../../../components/VerseTabs.jsx';
import ManuscriptCarousel from '../../../../../components/ManuscriptCarousel.jsx';
import VideosGrid from '../../../../../components/VideosGrid.astro';
import { R2_BASE_URL } from '../../../../../utils/cdn_config.js';
import { getBibleOgImage } from '../../../../../utils/ogImageResolver.js';
import { query } from '../../../../../db.js';
import booksMeta from '../../../../../data/books_meta.json';
import { parseMarkdown } from '../../../../../utils/markdown.js';
import { mapMtToLxx, mapLxxToMt } from '../../../../../utils/scripture_mapper.js';
import { BUILD_BOOKS } from '../../../../../utils/build_config.js';
import { R2_BASE_URL } from '../../../../../utils/cdn_config.js';
import { getScriptureVerseText, getScriptureVerseTextById } from '../../../../../utils/scripture_service.js';
import { enrichVideosWithVerses } from '../../../../../utils/video_service.js';

// 1. Pre-render sub-path page routes
export async function getStaticPaths() {
  const msNt = query("SELECT DISTINCT verse_id FROM manuscript_per_verse").map(r => r.verse_id);
  const msOtRows = query("SELECT DISTINCT verse_id, v11n_type FROM manuscript_per_verse_ot");
  const msOt = msOtRows.map(r => {
    if (r.v11n_type === 'MT') {
      const p = r.verse_id.split('_');
      const mapped = mapMtToLxx(p[0], p[1], p[2]);
      return `${mapped.book}_${mapped.chapter}_${mapped.verse}`;
    }
    return r.verse_id;
  });

  const ctRaw = query("SELECT DISTINCT verse1 as v FROM contradictions UNION SELECT DISTINCT verse2 FROM contradictions").map(r => r.v);
  const apRaw = query("SELECT DISTINCT verse FROM apologetics").map(r => r.verse);
  const vdRaw = query("SELECT DISTINCT verse_id FROM short_per_verse").map(r => r.verse_id);

  const mapToLxxIfOt = (id) => {
    if (!id) return null;
    const p = id.split('_');
    if (booksMeta.ot.some(b => b.id === p[0])) {
      const m = mapMtToLxx(p[0], p[1], p[2]);
      return `${m.book}_${m.chapter}_${m.verse}`;
    }
    return id;
  };

  const ct = ctRaw.map(mapToLxxIfOt);
  const ap = apRaw.map(mapToLxxIfOt);
  const vd = vdRaw.map(mapToLxxIfOt);

  const msSet = new Set([...msNt, ...msOt]);
  const ctSet = new Set(ct);
  const apSet = new Set(ap);
  const vdSet = new Set(vd);

  const allVerseIds = new Set([...msSet, ...ctSet, ...apSet, ...vdSet].filter(Boolean));
  const paths = [];

  const booksToBuild = BUILD_BOOKS;

  allVerseIds.forEach(id => {
    const parts = id.split('_');
    if (parts.length === 3) {
      const b = parts[0];
      const c = parts[1];
      const v = parts[2];

      if (booksToBuild && !booksToBuild.has(b)) return;

      if (msSet.has(id)) paths.push({ params: { book: b, chapter: c, verse: v, tab: 'manuscripts' } });
      if (ctSet.has(id)) paths.push({ params: { book: b, chapter: c, verse: v, tab: 'contradictions' } });
      if (apSet.has(id)) paths.push({ params: { book: b, chapter: c, verse: v, tab: 'apologetics' } });
      if (vdSet.has(id)) paths.push({ params: { book: b, chapter: c, verse: v, tab: 'videos' } });
    }
  });

  return BUILD_BOOKS ? paths.filter(p => BUILD_BOOKS.has(p.params.book)) : paths;
}

const { book, chapter, verse, tab } = Astro.params;
const verseId = `${book}_${chapter}_${verse}`;

// 2. Find Book Details
const isNT = booksMeta.nt.some(b => b.id === book);
const bookMeta = isNT
  ? booksMeta.nt.find(b => b.id === book)
  : booksMeta.ot.find(b => b.id === book);

if (!bookMeta) {
  return Astro.redirect('/404');
}

const mtObj = mapLxxToMt(book, chapter, verse);
const mtId = `${mtObj.book}_${mtObj.chapter}_${mtObj.verse}`;
const checkId = isNT ? verseId : mtId;

// 3. Query active evidence counts
const msCount = isNT
  ? query("SELECT COUNT(DISTINCT image_name) as count FROM manuscript_per_verse WHERE verse_id = :verseId", { verseId })[0].count
  : query("SELECT COUNT(DISTINCT image_name) as count FROM manuscript_per_verse_ot WHERE (verse_id = :lxxId AND v11n_type = 'LXX') OR (verse_id = :mtId AND v11n_type = 'MT')", { lxxId: verseId, mtId })[0].count;

const ctCount = query("SELECT COUNT(DISTINCT title) as count FROM contradictions WHERE verse1 = :checkId OR verse2 = :checkId", { checkId })[0].count;
const apCount = query("SELECT COUNT(DISTINCT title) as count FROM apologetics WHERE verse = :checkId", { checkId })[0].count;
const vdCount = query("SELECT COUNT(DISTINCT video_id) as count FROM short_per_verse WHERE verse_id = :checkId", { checkId })[0].count;

// 3.5 Load Verse Text
const verseText = getScriptureVerseText(book, chapter, verse);

// 4. Query active evidence data
let manuscripts = [];
let contradictions = [];
let apologetics = [];
let videos = [];

if (tab === 'manuscripts') {
  const rawManuscripts = isNT ? query(`
    SELECT m.image_name, mm.*
    FROM manuscript_per_verse m
    LEFT JOIN manuscripts_meta mm ON m.ms_id = mm.ms_id
    WHERE m.verse_id = :verseId
    ORDER BY mm.earliest_date ASC
  `, { verseId }) : query(`
    SELECT m.image_name, mm.*
    FROM manuscript_per_verse_ot m
    LEFT JOIN manuscripts_meta_ot mm ON m.ms_id = mm.ms_id
    WHERE (m.verse_id = :lxxId AND m.v11n_type = 'LXX')
       OR (m.verse_id = :mtId AND m.v11n_type = 'MT')
    ORDER BY mm.earliest_date ASC
  `, { lxxId: verseId, mtId });

  // Automatic Page/Scan Indexing (Prevents duplicates confusion for P66, etc.)
  const msCounts = {};
  rawManuscripts.forEach(ms => {
    if (ms.ms_id) {
      msCounts[ms.ms_id] = (msCounts[ms.ms_id] || 0) + 1;
    }
  });

  const msTracker = {};
  manuscripts = rawManuscripts.map(ms => {
    const total = msCounts[ms.ms_id] || 0;
    let displayName = ms.name || ms.ms_id;

    if (total > 1) {
      msTracker[ms.ms_id] = (msTracker[ms.ms_id] || 0) + 1;
      displayName = `${ms.name || ms.ms_id} (Scan ${msTracker[ms.ms_id]})`;
    }

    return {
      ...ms,
      name: displayName
    };
  });
}

if (tab === 'contradictions') {
  contradictions = query(`
    SELECT c.*, m.name as meta_name, m.url as meta_url, m.copyright as meta_copyright,
           pw.name as work_name, pw.url as work_url,
           pf.id as father_id, pf.name as father_name, pf.year as father_year, pf.icon as father_icon,
           CASE
             WHEN pf.id IS NOT NULL THEN 1
             WHEN c.src = 'answering_islam' THEN 2
             WHEN c.src = 'tektonics' THEN 3
             WHEN c.src = 'apologetic_apologetics_press' THEN 4
             WHEN c.src = 'apologetic_defending_inerrancy' THEN 5
             WHEN c.src = 'carm' THEN 6
             WHEN c.src = 'gotquestions' THEN 7
             WHEN c.src = 'answersingenesis' THEN 8
             ELSE 9
           END as sort_order
    FROM contradictions c
    LEFT JOIN apologetics_meta m ON c.src = m.id
    LEFT JOIN patristics_works pw ON c.src = pw.id
    LEFT JOIN patristics_fathers pf ON pw.father_id = pf.id
    WHERE c.verse1 = :checkId OR c.verse2 = :checkId
    GROUP BY c.title
    ORDER BY sort_order ASC, pf.year ASC
  `, { checkId });
}

if (tab === 'apologetics') {
  apologetics = query(`
    SELECT a.*, m.name as meta_name, m.url as meta_url, m.copyright as meta_copyright,
           pw.name as work_name, pw.url as work_url,
           pf.id as father_id, pf.name as father_name, pf.year as father_year, pf.icon as father_icon,
           CASE
             WHEN pf.id IS NOT NULL THEN 1
             WHEN a.src = 'answering_islam' THEN 2
             WHEN a.src = 'tektonics' THEN 3
             WHEN a.src = 'apologetic_apologetics_press' THEN 4
             WHEN a.src = 'apologetic_defending_inerrancy' THEN 5
             WHEN a.src = 'carm' THEN 6
             WHEN a.src = 'gotquestions' THEN 7
             WHEN a.src = 'answersingenesis' THEN 8
             ELSE 9
           END as sort_order
    FROM apologetics a
    LEFT JOIN apologetics_meta m ON a.src = m.id
    LEFT JOIN patristics_works pw ON a.src = pw.id
    LEFT JOIN patristics_fathers pf ON pw.father_id = pf.id
    WHERE a.verse = :checkId
    GROUP BY a.title
    ORDER BY sort_order ASC, pf.year ASC
  `, { checkId });
}

if (tab === 'videos') {
  const rawVideos = query(`
    SELECT sm.*
    FROM short_per_verse spv
    JOIN shorts_metadata sm ON spv.video_id = sm.video_id
    WHERE spv.verse_id = :checkId
  `, { checkId });
  videos = enrichVideosWithVerses(rawVideos, import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL);
}

function formatBookIdToName(id) {
  if (!id) return '';
  const bookCode = id.split('_')[0];
  const found = booksMeta.nt.find(b => b.id === bookCode) || booksMeta.ot.find(b => b.id === bookCode);
  return found ? found.name : bookCode.toUpperCase();
}

function formatVerseIdToLabel(id) {
  if (!id) return '';
  const p = id.split('_');
  if (booksMeta.ot.some(b => b.id === p[0])) {
    const m = mapMtToLxx(p[0], p[1], p[2]);
    return `${formatBookIdToName(id)} ${m.chapter}:${m.verse}`;
  }
  return `${formatBookIdToName(id)} ${p[1]}:${p[2]}`;
}

function formatVerseIdToLink(id) {
  if (!id) return '';
  const p = id.split('_');
  const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
  if (booksMeta.ot.some(b => b.id === p[0])) {
    const m = mapMtToLxx(p[0], p[1], p[2]);
    return `${base}/bible/${m.book}/${m.chapter}/${m.verse}/contradictions`;
  }
  return `${base}/bible/${p[0]}/${p[1]}/${p[2]}/contradictions`;
}
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

// Generate OG Image from the oldest manuscript
const ogImage = getBibleOgImage(book, chapter, verse, isNT);

const { seoTitle, seoDescription, seoKeywords, seoSchema } = generateBibleTabSEO({
  tab,
  bookName: bookMeta.name,
  chapter,
  verse,
  manuscripts,
  contradictions,
  apologetics,
  isNT
});
---

<Layout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  ogImage={ogImage}
  schema={seoSchema}
>
  <div class="verse-detail-container">

    <!-- Top Header Back Navigation -->
    <header class="detail-header select-none">
      <a href={`${base}/bible/${book}/${chapter}#${verse}`} class="back-btn" aria-label="Go back to chapter reader">
        <span class="back-arrow">
          <svg width="6" height="10" fill="none" stroke="currentColor" viewBox="0 0 6 10" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 9L1 5l4-4" />
          </svg>
        </span>
        <span>{bookMeta.name} {chapter}</span>
      </a>

      <!-- Minimalist Heading showing exactly John 1:1 with subtle Settings Ellipsis -->
      <div style="display: flex; align-items: center; gap: 8px;">
        <h2 class="verse-drawer-title">
          {bookMeta.name} {chapter}:{verse}
        </h2>
        <button id="open-tab-settings-btn" class="subtle-ellipsis-btn" aria-label="Customize Verse View" title="Customize Tabs">
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 12a2 2 0 114 0 2 2 0 01-4 0zm8 0a2 2 0 114 0 2 2 0 01-4 0zm8 0a2 2 0 114 0 2 2 0 01-4 0z" />
          </svg>
        </button>
      </div>
    </header>

    {verseText && (
      <div class="verse-text-reminder select-text">
        "{verseText}"
      </div>
    )}

    <script>
      // Trigger the React modal from the static Astro shell
      // Listen to astro:page-load to re-attach the event listener after View Transitions navigation
      document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('open-tab-settings-btn');
        if (btn) {
          // Remove old listener to prevent duplicates if the element wasn't destroyed
          btn.onclick = () => {
            window.dispatchEvent(new CustomEvent('open-tab-settings'));
          };
        }
      });
    </script>

    <!-- Static Segmented Tab switcher anchors -->
    <VerseTabs
      client:load
      msCount={msCount}
      ctCount={ctCount}
      apCount={apCount}
      videosCount={vdCount}
      activeTab={tab}
      book={book}
      chapter={chapter}
      verse={verse}
    />

    <!-- ACTIVE TAB PANEL CONTENTS -->
    <div class="tab-panels-window">

      {tab === 'manuscripts' && (
        <div>
          <ManuscriptCarousel
            client:load
            manuscripts={manuscripts}
            verseId={verseId}
            verseLabel={`${bookMeta.name} ${chapter}:${verse}`}
            isNT={isNT}
          />
        </div>
      )}

      {tab === 'contradictions' && (
        <div class="contradiction-panel-container">
          {contradictions.length > 0 ? (
            contradictions.map((ct, index) => {
              const otherVerseId = ct.verse1 === checkId ? ct.verse2 : ct.verse1;
              const otherVerseLabel = formatVerseIdToLabel(otherVerseId);
              const otherVerseLink = formatVerseIdToLink(otherVerseId);
              const otherVerseText = getScriptureVerseTextById(otherVerseId);

              // Determine if details panel is open by default (always open if 1, pre-open 1st if multiple)
              const isInitiallyOpen = contradictions.length === 1 || index === 0;

              return (
                <details open={isInitiallyOpen} class="contradiction-details-card">

                  {/* Interactive Accordion Header Title */}
                  <summary class="contradiction-summary-header select-none">
                    <span class="summary-title">{ct.title}</span>
                    <span class="summary-chevron">
                      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                      </svg>
                    </span>
                  </summary>

                  {/* Collapsible Content Panel */}
                  <div class="contradiction-card-content">

                    {otherVerseId && (
                      <div class="contrasting-verse-section">
                        <div class="contrasting-badge-box select-none">
                          <span class="badge-box-label">Contrasting Link:</span>
                          <a href={otherVerseLink} class="contrasting-link-pill">
                            <span>{otherVerseLabel}</span>
                            <span class="link-arrow">&rarr;</span>
                          </a>
                        </div>
                        {otherVerseText && (
                          <div class="verse-text-reminder select-text contradicting-text-box">
                            "{otherVerseText}"
                          </div>
                        )}
                      </div>
                    )}

                    {/* Optional AI Summary */}
                    {ct.summary && (
                      <div class="ai-summary-box select-none">
                        <span class="ai-icon" title="AI Generated Summary">
                          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                          </svg>
                        </span>
                        <div class="ai-summary-text" set:html={parseMarkdown(ct.summary)} />
                      </div>
                    )}

                    {/* Rich Markdown body parser */}
                    <div class="card-response-body select-text">
                      <div set:html={parseMarkdown(ct.answer)} />
                    </div>

                    {/* Subtle Source Meta Credit Footer */}
                    <div class="card-footer-source-box select-none">
                      {ct.father_id ? (
                        <div class="patristics-meta-box">
                          <img src={ct.father_icon} alt={ct.father_name} class="father-icon" loading="lazy" decoding="async" />
                          <div class="patristics-text">
                            <span class="father-name-text">{ct.father_name} <span class="father-year">({ct.father_year > 0 ? `AD ${ct.father_year}` : `${Math.abs(ct.father_year)} BC`})</span></span>
                            <span class="work-name-text">{ct.work_name}</span>
                          </div>
                        </div>
                      ) : (
                        <div class="source-meta-text">
                          <span class="source-meta-label">Source:</span>
                          <span class="source-name-text">{ct.meta_name || ct.src}</span>
                          {ct.meta_copyright && <span class="source-copyright-text">({ct.meta_copyright})</span>}
                        </div>
                      )}
                      {(ct.work_url || ct.meta_url) && (
                        <a href={ct.work_url || ct.meta_url} target="_blank" rel="noopener noreferrer" class="source-visit-pill-btn" title="Visit website page source">
                          <span>{ct.father_id ? 'Read Text' : 'Visit Source'}</span>
                          <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </a>
                      )}
                    </div>

                  </div>

                </details>
              );
            })
          ) : (
            <p class="empty-tabs-placeholder">No alleged contradictions mapped for this verse.</p>
          )}
        </div>
      )}

      {tab === 'apologetics' && (
        <div class="apologetics-panel-container">
          {apologetics.length > 0 ? (
            apologetics.map((ap, index) => {
              // Determine if details panel is open by default (always open if 1, pre-open 1st if multiple)
              const isInitiallyOpen = apologetics.length === 1 || index === 0;

              return (
                <details open={isInitiallyOpen} class="apologetics-details-card">

                  {/* Interactive Accordion Header Title */}
                  <summary class="apologetics-summary-header select-none">
                    <span class="summary-title">{ap.title}</span>
                    <span class="summary-chevron">
                      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                      </svg>
                    </span>
                  </summary>

                  {/* Collapsible Content Panel */}
                  <div class="apologetics-card-content">

                    {/* Optional AI Summary */}
                    {ap.summary && (
                      <div class="ai-summary-box select-none">
                        <span class="ai-icon" title="AI Generated Summary">
                          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                          </svg>
                        </span>
                        <div class="ai-summary-text" set:html={parseMarkdown(ap.summary)} />
                      </div>
                    )}

                    {/* Rich Markdown body parser */}
                    <div class="card-response-body select-text">
                      <div set:html={parseMarkdown(ap.answer)} />
                    </div>

                    {/* Subtle Source Meta Credit Footer */}
                    <div class="card-footer-source-box select-none">
                      {ap.father_id ? (
                        <div class="patristics-meta-box">
                          <img src={ap.father_icon} alt={ap.father_name} class="father-icon" loading="lazy" decoding="async" />
                          <div class="patristics-text">
                            <span class="father-name-text">{ap.father_name} <span class="father-year">({ap.father_year > 0 ? `AD ${ap.father_year}` : `${Math.abs(ap.father_year)} BC`})</span></span>
                            <span class="work-name-text">{ap.work_name}</span>
                          </div>
                        </div>
                      ) : (
                        <div class="source-meta-text">
                          <span class="source-meta-label">Source:</span>
                          <span class="source-name-text">{ap.meta_name || ap.src}</span>
                          {ap.meta_copyright && <span class="source-copyright-text">({ap.meta_copyright})</span>}
                        </div>
                      )}
                      {(ap.work_url || ap.meta_url) && (
                        <a href={ap.work_url || ap.meta_url} target="_blank" rel="noopener noreferrer" class="source-visit-pill-btn" title="Visit website page source">
                          <span>{ap.father_id ? 'Read Text' : 'Visit Source'}</span>
                          <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </a>
                      )}
                    </div>

                  </div>

                </details>
              );
            })
          ) : (
            <p class="empty-tabs-placeholder">No apologetics defenses mapped for this verse.</p>
          )}
        </div>
      )}

      {tab === 'videos' && (
        <div class="videos-panel-container">
          <VideosGrid videos={videos} />
        </div>
      )}

    </div>
  </div>
</Layout>

<style>
	/* ==========================================
	   Tab Sub-Path Detail View CSS
	   ========================================== */
	.verse-detail-container {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	/* Header Apple Navigation */
	.detail-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-bottom: 1px solid var(--color-outline-variant);
		padding-bottom: 14px;
	}

	.back-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 12px;
		background-color: var(--color-surface-container-low);
		color: var(--color-on-surface-variant);
		border: 1px solid var(--color-outline-variant);
		border-radius: 8px;
		font-size: 11px;
		font-weight: 700;
		text-decoration: none;
		transition: all 0.15s ease;
	}
	.back-btn:hover {
		background-color: var(--color-outline-variant);
		color: var(--color-primary);
	}
	.back-btn:active {
		transform: scale(0.97);
	}
	.back-arrow {
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.back-arrow svg {
		stroke: currentColor;
		fill: none;
	}

	.verse-drawer-title {
		font-family: var(--font-display);
		font-size: 22px;
		font-weight: 800;
		color: var(--color-primary);
		margin: 0;
		letter-spacing: -0.01em;
	}

	.verse-text-reminder {
		font-family: var(--font-display);
		font-size: 13px;
		line-height: 1.4;
		color: var(--color-on-surface-variant);
		font-style: italic;
		padding: 10px 14px;
		background-color: var(--color-surface-container-lowest);
		border-left: 3px solid var(--color-outline-variant);
		border-radius: 0 8px 8px 0;
		margin-bottom: 4px;
	}

	.subtle-ellipsis-btn {
		background: transparent;
		border: none;
		color: var(--color-on-surface-variant);
		opacity: 0.6;
