---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../../layouts/Layout.astro';
import { query } from '../../../db.js';
import booksMeta from '../../../data/books_meta.json';
import { mapLxxToMt, mapMtToLxx } from '../../../utils/scripture_mapper.js';
import { BUILD_BOOKS } from '../../../utils/build_config.js';
import { loadAllTopicsData } from '../../../utils/topicsLoader.js';
import { getTopicColor } from '../../../utils/topicColors.js';

// 1. Pre-render all chapters for NT and OT books
export async function getStaticPaths() {
  const paths = [];

  booksMeta.nt.forEach(book => {
    for (let c = 1; c <= book.chapters; c++) {
      paths.push({ params: { book: book.id, chapter: String(c) } });
    }
  });

  booksMeta.ot.forEach(book => {
    for (let c = 1; c <= book.chapters; c++) {
      paths.push({ params: { book: book.id, chapter: String(c) } });
    }
  });

  return BUILD_BOOKS ? paths.filter(p => BUILD_BOOKS.has(p.params.book)) : paths;
}

const { book, chapter } = Astro.params;

// 2. Find Book Details
const isNT = booksMeta.nt.some(b => b.id === book);
const bookMeta = isNT
  ? booksMeta.nt.find(b => b.id === book)
  : booksMeta.ot.find(b => b.id === book);

if (!bookMeta) {
  return Astro.redirect('/404');
}

// 3. Load Scripture Content from JSON
const folder = isNT ? 'esv' : 'lxx2012';
const filePath = path.join(process.cwd(), 'src/data/scripture', folder, `${book}.json`);
let chapterVerses = [];

try {
  const fileContent = fs.readFileSync(filePath, 'utf-8');
  const bookData = JSON.parse(fileContent);
  chapterVerses = bookData[chapter] || [];
} catch (err) {
  console.error(`Failed to read scripture file: ${filePath}`, err);
}

// 4. Populate active evidence per verse
const evidenceMap = {};

const lxxPrefix = `${book}_${chapter}_%`;
const mtPrefix = isNT ? '' : `${mapLxxToMt(book, chapter, '1').book}_%`;

const msSet = new Set(
  isNT
    ? query("SELECT verse_id FROM manuscript_per_verse WHERE verse_id LIKE :p", { p: lxxPrefix }).map(r => r.verse_id)
    : query("SELECT verse_id, v11n_type FROM manuscript_per_verse_ot WHERE verse_id LIKE :lxx OR verse_id LIKE :mt", { lxx: lxxPrefix, mt: mtPrefix }).map(r => {
        if (r.v11n_type === 'MT') {
          const p = r.verse_id.split('_');
          const m = mapMtToLxx(p[0], p[1], p[2]);
          return `${m.book}_${m.chapter}_${m.verse}`;
        }
        return r.verse_id;
      })
);

const ctSet = new Set(
  query("SELECT verse1 as v FROM contradictions WHERE verse1 LIKE :lxx OR verse1 LIKE :mt UNION SELECT verse2 as v FROM contradictions WHERE verse2 LIKE :lxx OR verse2 LIKE :mt", { lxx: lxxPrefix, mt: mtPrefix }).map(r => {
    const p = r.v.split('_');
    if (!isNT) {
      const m = mapMtToLxx(p[0], p[1], p[2]);
      return `${m.book}_${m.chapter}_${m.verse}`;
    }
    return r.v;
  })
);

const apSet = new Set(
  query("SELECT verse FROM apologetics WHERE verse LIKE :lxx OR verse LIKE :mt", { lxx: lxxPrefix, mt: mtPrefix }).map(r => {
    const p = r.verse.split('_');
    if (!isNT) {
      const m = mapMtToLxx(p[0], p[1], p[2]);
      return `${m.book}_${m.chapter}_${m.verse}`;
    }
    return r.verse;
  })
);

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

const formatRef = (vId) => {
  const p = vId.split('_');
  const bMeta = [...booksMeta.nt, ...booksMeta.ot].find(b => b.id === p[0]);
  const bName = bMeta ? bMeta.name : p[0];
  return `<a href="${base}/bible/${p[0]}/${p[1]}#${p.slice(2).join('_')}">${bName} ${p[1]}:${p.slice(2).join('_')}</a>`;
};

const topicMap = {};
const topicNotesMap = {};
loadAllTopicsData().forEach(({ topicId, topicData }) => {
  ['Old Testament', 'New Testament'].forEach(test => {
    const bank = topicData?.Scripture?.[test]?.verse_bank;
    if (bank && typeof bank === 'object') {
      Object.keys(bank).forEach(vId => {
        const parts = vId.split('_');
        if (parts[0] === book && parts[1] === chapter) {
          const vNum = parts.slice(2).join('_');
          if (!topicMap[vNum]) topicMap[vNum] = [];
          topicMap[vNum].push(topicId);
          if (!topicNotesMap[vNum]) topicNotesMap[vNum] = {};
          topicNotesMap[vNum][topicId] = bank[vId];
        }
      });
    }
  });

  if (Array.isArray(topicData?.prophecies)) {
    topicData.prophecies.forEach(prophecy => {
      const otRefs = (prophecy.ot_verses || []).map(formatRef).join(', ');

      (prophecy.ot_verses || []).forEach(vId => {
        const parts = vId.split('_');
        if (parts[0] === book && parts[1] === chapter) {
          const vNum = parts.slice(2).join('_');
          if (!topicMap[vNum]) topicMap[vNum] = [];
          if (!topicMap[vNum].includes(topicId)) topicMap[vNum].push(topicId);

          const ntListItems = (prophecy.nt_fulfillments || []).map(nt => {
            const ntRefs = (nt.verses || []).map(formatRef).join(', ');
            return `<li>${ntRefs}</li>`;
          }).join('');
          const noteHtml = `<div><strong>Prophecy:</strong> ${prophecy.name}</div><div style="margin-top: 8px;"><strong>Fulfillments:</strong></div><ul style="margin: 4px 0 0; padding-left: 16px;">${ntListItems}</ul>`;

          if (!topicNotesMap[vNum]) topicNotesMap[vNum] = {};
          topicNotesMap[vNum][topicId] = noteHtml;
        }
      });
      (prophecy.nt_fulfillments || []).forEach(nt => {
        (nt.verses || []).forEach(vId => {
          const parts = vId.split('_');
          if (parts[0] === book && parts[1] === chapter) {
            const vNum = parts.slice(2).join('_');
            if (!topicMap[vNum]) topicMap[vNum] = [];
            if (!topicMap[vNum].includes(topicId)) topicMap[vNum].push(topicId);

            const noteHtml = `<div><strong>Prophecy:</strong> ${prophecy.name}</div><div style="margin-top: 8px;"><strong>Promise:</strong> ${otRefs}</div>` + (nt.note ? `<div style="margin-top: 8px;"><strong>Note:</strong> ${nt.note}</div>` : '');

            if (!topicNotesMap[vNum]) topicNotesMap[vNum] = {};
            topicNotesMap[vNum][topicId] = noteHtml;
          }
        });
      });
    });
  }
});

chapterVerses.forEach(verseObj => {
  const verseNum = Object.keys(verseObj)[0];
  const lxxId = `${book}_${chapter}_${verseNum}`;

  const types = [];
  if (msSet.has(lxxId)) types.push('manuscript');
  if (ctSet.has(lxxId)) types.push('contradiction');
  if (apSet.has(lxxId)) types.push('apologetics');

  if (types.length > 0) {
    evidenceMap[verseNum] = types;
  }
});

const currentChapterNum = parseInt(chapter);
const hasPrev = currentChapterNum > 1;
const hasNext = currentChapterNum < bookMeta.chapters;

// Generate OG Image from the oldest manuscript of chapter 1, verse 1 of this book
let ogImage = undefined;
const v11Id = `${book}_1_1`;
if (isNT) {
  const earliestMs = query(`
    SELECT m.ms_id, m.image_name
    FROM manuscript_per_verse m
    JOIN manuscripts_meta mm ON m.ms_id = mm.ms_id
    WHERE m.verse_id = :v11Id
    ORDER BY mm.earliest_date ASC
    LIMIT 1
  `, { v11Id });
  if (earliestMs.length > 0 && earliestMs[0].image_name) {
    ogImage = `https://pub-219566f197174e27a10f51e5fb2414f6.r2.dev/images/${earliestMs[0].ms_id}/${encodeURIComponent(earliestMs[0].image_name)}`;
  }
} else {
  try {
    const mtMappingV11 = mapLxxToMt(book, '1', '1');
    const mtIdV11 = `${mtMappingV11.book}_${mtMappingV11.chapter}_${mtMappingV11.verse}`;
    const earliestMsOt = query(`
      SELECT m.ms_id, m.image_name
      FROM manuscript_per_verse_ot m
      JOIN manuscripts_meta_ot mm ON m.ms_id = mm.ms_id
      WHERE m.verse_id = :v11Id OR m.verse_id = :mtIdV11
      ORDER BY mm.earliest_date ASC
      LIMIT 1
    `, { v11Id, mtIdV11 });
    if (earliestMsOt.length > 0 && earliestMsOt[0].image_name) {
      ogImage = `https://pub-219566f197174e27a10f51e5fb2414f6.r2.dev/ot_images/${earliestMsOt[0].ms_id}/${encodeURIComponent(earliestMsOt[0].image_name)}`;
    }
  } catch(e) {}
}

const allTopics = loadAllTopicsData();
const topicsMeta = allTopics.reduce((acc, t) => {
  const name = t.topicData.name || t.topicId.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
  acc[t.topicId] = { title: name, color: getTopicColor(t.topicId) };
  return acc;
}, {});
---

<Layout title={`${bookMeta.name} ${chapter}`} ogImage={ogImage}>
  <div class="chapter-reader-container">

    <!-- Split Book & Chapter Dropdown Selector -->
    <header class="reader-header select-none">
      <div class="selector-hub">
        <!-- 1. Book Name Selector (Clicking 'John' opens Left Navigation Menu) -->
        <button class="book-selector-btn book-title" onclick="document.getElementById('nav-toggle-btn').click()">
          {bookMeta.name}
        </button>

        <!-- 2. Chapter Number Selector (Clicking '1' opens inline Chapter Grid dropdown!) -->
        <div class="chapter-dropdown-wrapper">
          <button class="chapter-selector-btn" id="chapter-popover-trigger" aria-label="Select Chapter">
            <span>{chapter}</span>
            <span class="chevron-down">
              <svg width="8" height="5" fill="none" stroke="currentColor" viewBox="0 0 10 6" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M1 1l4 4 4-4" />
              </svg>
            </span>
          </button>

          <!-- Absolute Positioned Chapter Dropdown Popover -->
          <div class="chapter-dropdown-popover" id="chapter-dropdown-popover">
            <div class="popover-grid-scroll">
              <div class="chapter-popover-grid">
                {Array.from({ length: bookMeta.chapters }, (_, i) => i + 1).map(c => (
                  <a
                    href={`${base}/bible/${book}/${c}`}
                    class={`popover-chap-link ${c === currentChapterNum ? 'active' : ''}`}
                  >
                    {c}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Scripture Verses -->
    <div class="verses-container" data-topics-meta={JSON.stringify(topicsMeta)}>
      {chapterVerses.length > 0 ? (
        chapterVerses.map(verseObj => {
          const verseNum = Object.keys(verseObj)[0];
          const verseText = verseObj[verseNum];

          const evidenceTypes = evidenceMap[verseNum] || [];
          const hasEvidence = evidenceTypes.length > 0;

          if (hasEvidence) {
            return (
              <div class="verse-row active-verse" id={verseNum} data-topics={topicMap[verseNum] ? topicMap[verseNum].join(',') : ''} data-topic-notes={topicNotesMap[verseNum] ? JSON.stringify(topicNotesMap[verseNum]) : ''}>
                <div class="verse-row-content">
                  <span class="verse-num">{verseNum}</span>
                  <div class="verse-body-wrapper">
                    <p class="verse-text">
                      {/* Tapping the verse text redirects to the evidence redirect gate */}
                      <a href={`${base}/bible/${book}/${chapter}/${verseNum}`} class="verse-text-link-wrapper">
                        {verseText}
                      </a>

                      {/* Tapping individual badges routes DIRECTLY to their evidence tab pages! */}
                      <span class="verse-badge-tray-inline">
                        {evidenceTypes.includes('manuscript') && (
                          <a
                            href={`${base}/bible/${book}/${chapter}/${verseNum}/manuscripts`}
                            class="icon-inline ms-icon"
                            title="Manuscripts available"
                          >
                            <svg viewBox="0 0 24 24" stroke-width="2.5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                          </a>
                        )}
                        {evidenceTypes.includes('contradiction') && (
                          <a
                            href={`${base}/bible/${book}/${chapter}/${verseNum}/contradictions`}
                            class="icon-inline ct-icon"
                            title="Alleged contradictions available"
                          >
                            <svg viewBox="0 0 24 24" stroke-width="2.5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7h3.5m5.5 0H18m0 0l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9h-3.5M10 5h4m-2-3v18m-5-3h10" />
                            </svg>
                          </a>
                        )}
                        {evidenceTypes.includes('apologetics') && (
                          <a
                            href={`${base}/bible/${book}/${chapter}/${verseNum}/apologetics`}
                            class="icon-inline ap-icon"
                            title="Apologetics defenses available"
                          >
                            <svg viewBox="0 0 24 24" stroke-width="2.5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                            </svg>
                          </a>
                        )}
                      </span>
                    </p>
                  </div>
                </div>
              </div>
            );
          } else {
            return (
              <div class="verse-row" id={verseNum} data-topics={topicMap[verseNum] ? topicMap[verseNum].join(',') : ''} data-topic-notes={topicNotesMap[verseNum] ? JSON.stringify(topicNotesMap[verseNum]) : ''}>
                <div class="verse-row-content">
                  <span class="verse-num muted">{verseNum}</span>
                  <div class="verse-body-wrapper">
                    <p class="verse-text muted-text">{verseText}</p>
                  </div>
                </div>
              </div>
            );
          }
        })
      ) : (
        <div class="empty-state">
          Scripture content not loaded.
        </div>
      )}
    </div>

    <!-- Pagination Footer -->
    <div class="pagination-footer select-none">
      {hasPrev ? (
        <a
          href={`${base}/bible/${book}/${currentChapterNum - 1}`}
          class="pager-btn"
        >
          &larr; Chapter {currentChapterNum - 1}
        </a>
      ) : (
        <div class="pager-placeholder"></div>
      )}

      <span class="pager-indicator">
        {currentChapterNum} / {bookMeta.chapters}
      </span>

      {hasNext ? (
        <a
          href={`${base}/bible/${book}/${currentChapterNum + 1}`}
          class="pager-btn"
        >
          Chapter {currentChapterNum + 1} &rarr;
        </a>
      ) : (
        <div class="pager-placeholder"></div>
      )}
    </div>
  </div>
</Layout>

<!-- Inline Chapter Dropdown Trigger script -->
<script is:inline data-astro-rerun>
  try {
    localStorage.setItem('lastVisitedUrl', window.location.pathname);
  } catch (e) {
    console.warn('Failed to save last visited URL:', e);
  }
  let closePopoverHandler;

  const setupChapterPopover = () => {
    const trigger = document.getElementById('chapter-popover-trigger');
    const popover = document.getElementById('chapter-dropdown-popover');

    if (!trigger || !popover) return;

    trigger.addEventListener('click', (e) => {
      e.stopPropagation(); // Prevent immediate backdrop close
      popover.classList.toggle('open');
    });

    if (closePopoverHandler) {
      document.removeEventListener('click', closePopoverHandler);
    }

    closePopoverHandler = () => {
      popover.classList.remove('open');
    };

    // Tap outside closes popover
    document.addEventListener('click', closePopoverHandler);

    // Prevent close if clicking inside grid
    popover.addEventListener('click', (e) => {
      e.stopPropagation();
    });
  };

  const setupTopicHighlight = () => {
    let activeTopics = [];
    try {
      activeTopics = JSON.parse(localStorage.getItem('activeTopics') || '[]');
    } catch(e) {}

    // Legacy single topic support
    const legacyTopic = localStorage.getItem('activeTopic');
    if (legacyTopic && !activeTopics.length) {
      activeTopics = [legacyTopic];
      localStorage.setItem('activeTopics', JSON.stringify(activeTopics));
      localStorage.removeItem('activeTopic');
    }

    const container = document.querySelector('.verses-container');
    const topicsMeta = container ? JSON.parse(container.getAttribute('data-topics-meta') || '{}') : {};

    document.querySelectorAll('.verse-row[data-topics]').forEach(el => {
      const verseTopicsStr = el.getAttribute('data-topics');
      if (!verseTopicsStr) return;

      const verseTopics = verseTopicsStr.split(',');
      const intersection = activeTopics.filter(t => verseTopics.includes(t));

      let existingPills = el.querySelector('.verse-topic-pills');
      if (existingPills) existingPills.remove();
      el.querySelectorAll('.topic-note-card').forEach(n => n.remove());

      if (intersection.length > 0) {
        el.classList.add('topic-highlight');

        const pillsContainer = document.createElement('div');
        pillsContainer.className = 'verse-topic-pills';

        const verseNotesStr = el.getAttribute('data-topic-notes');
        let verseNotes = {};
        try { verseNotes = JSON.parse(verseNotesStr || '{}'); } catch(e) {}

        intersection.forEach(tId => {
          const meta = topicsMeta[tId];
          if (!meta) return;

          const hasNote = !!verseNotes[tId];
          const pill = document.createElement(hasNote ? 'button' : 'span');
          pill.className = 'topic-pill' + (hasNote ? ' clickable' : '');
          if (hasNote) {
            pill.type = 'button';
            pill.title = `View commentary note on ${meta.title}`;
            pill.setAttribute('aria-label', `View commentary note on ${meta.title}`);
          }
          pill.style.color = meta.color.hex;
          pill.style.backgroundColor = meta.color.bgHex;

          const titleSpan = document.createElement('span');
          titleSpan.textContent = meta.title;
          pill.appendChild(titleSpan);

          if (hasNote) {
            const infoIcon = document.createElement('span');
            infoIcon.className = 'pill-info-icon';
            infoIcon.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><path stroke-linecap="round" stroke-linejoin="round" d="M12 16v-4m0-4h.01"></path></svg>`;
            pill.appendChild(infoIcon);

            pill.addEventListener('click', (e) => {
              e.preventDefault();
              e.stopPropagation();

              let existingNote = el.querySelector(`.topic-note-card[data-note-topic="${tId}"]`);
              if (existingNote) {
                existingNote.remove();
                pill.classList.remove('note-open');
              } else {
                el.querySelectorAll('.topic-note-card').forEach(n => n.remove());
                el.querySelectorAll('.topic-pill').forEach(p => p.classList.remove('note-open'));

                pill.classList.add('note-open');
                const noteCard = document.createElement('div');
                noteCard.className = 'topic-note-card animate-fade-in';
                noteCard.setAttribute('data-note-topic', tId);
                noteCard.style.backgroundColor = meta.color.bgHex;
                noteCard.style.borderLeft = `3px solid ${meta.color.hex}`;
                noteCard.innerHTML = verseNotes[tId];

                const bodyWrapper = el.querySelector('.verse-body-wrapper');
                if (bodyWrapper) bodyWrapper.appendChild(noteCard);
              }
            });
          }

          pillsContainer.appendChild(pill);
        });

        const bodyWrapper = el.querySelector('.verse-body-wrapper');
        if (bodyWrapper) {
          bodyWrapper.appendChild(pillsContainer);
        }
      } else {
        el.classList.remove('topic-highlight');
      }
    });
  };

  setupChapterPopover();
  setupTopicHighlight();
  const handleBeforeSwap = () => {
    if (closePopoverHandler) {
      document.removeEventListener('click', closePopoverHandler);
    }
    document.removeEventListener('astro:before-swap', handleBeforeSwap);
  };
  document.addEventListener('astro:before-swap', handleBeforeSwap);
</script>

<style>
	/* ==========================================
	   Scripture Reader Core Layout
	   ========================================== */
	.chapter-reader-container {
		display: flex;
		flex-direction: column;
	}

	:global(.verse-topic-pills) {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 10px;
	}
	:global(.topic-pill) {
		font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", Roboto, Helvetica, Arial, sans-serif !important;
		font-size: 11.5px !important;
		font-weight: 600 !important;
		padding: 4px 10px !important;
		border-radius: 999px !important;
		border: 1px solid transparent;
		display: inline-flex !important;
		align-items: center !important;
		gap: 6px !important;
		letter-spacing: -0.01em;
		line-height: 1.2 !important;
		transition: all 0.15s ease;
		box-shadow: 0 1px 2px rgba(0,0,0,0.03);
		margin: 0; /* Reset for button elements */
	}
	:global(.topic-pill.clickable) {
		cursor: pointer;
	}
	:global(.topic-pill.clickable:hover) {
		filter: brightness(0.95);
		transform: scale(1.02);
	}
	:global(.topic-pill.note-open) {
		box-shadow: 0 0 0 1.5px currentColor !important;
	}
	:global(.pill-info-icon) {
		display: inline-flex !important;
		align-items: center !important;
		justify-content: center !important;
		margin: 0 -2px 0 1px !important;
		opacity: 0.75;
		transition: opacity 0.15s ease, transform 0.15s ease;
	}
	:global(.topic-pill.clickable:hover .pill-info-icon) {
		opacity: 1;
		transform: scale(1.1);
	}
	:global(.topic-note-card) {
		margin-top: 10px;
		padding: 12px 14px;
		border-radius: 0 8px 8px 0;
		font-family: var(--font-body);
		font-size: 13px;
		color: #1e293b;
		line-height: 1.5;
		box-shadow: 0 2px 6px rgba(0,0,0,0.04);
	}
	:global(.topic-note-card a) {
		color: var(--color-primary);
		text-decoration: underline;
		text-underline-offset: 2px;
	}
	:global(.topic-note-card a:hover) {
		color: var(--color-secondary);
	}


	.reader-header {
		margin-bottom: 20px;
		display: flex;
		justify-content: flex-start;
	}

	/* ============================================================
	   Split Book & Chapter Selector Layout
	   ============================================================ */
	.selector-hub {
		display: flex;
		align-items: center;
		gap: 8px;
		margin-left: -8px; /* Align with left layout margins */
		min-width: 0; /* Enable shrinking below content size */
		position: relative; /* Anchor chapter popover here to avoid right-edge overflow */
	}

	/* Book Selector Button ("John") */
	.book-selector-btn {
		background: none;
		border: none;
		padding: 6px 10px;
		border-radius: 8px;
		cursor: pointer;
		color: var(--color-primary);
		font-family: var(--font-display);
		font-size: 28px;
		font-weight: 800;
		transition: background-color 0.15s, transform 0.1s;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		min-width: 0; /* Important for flex child truncation */
		text-align: left;
	}
	.book-selector-btn:hover {
		background-color: var(--color-surface-container-low);
	}
