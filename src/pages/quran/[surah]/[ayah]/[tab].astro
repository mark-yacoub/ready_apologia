---
import fs from 'node:fs';
import path from 'node:path';

import { generateQuranTabSEO } from '../../../../utils/seoFactory.js';
import Layout from '../../../../layouts/Layout.astro';
import QuranVerseTabs from '../../../../components/QuranVerseTabs.jsx';
import QuranManuscriptCarousel from '../../../../components/QuranManuscriptCarousel.jsx';
import VideosGrid from '../../../../components/VideosGrid.astro';
import { query } from '../../../../db.js';
import { loadEnglishData } from '../../../../utils/quran_loader.js';
import { assignManuscriptScanNames } from '../../../../utils/manuscript_utils.js';
import { loadChristianFootnotes } from '../../../../utils/christian_footnotes_loader.js';
import { loadIslamicCommentaries } from '../../../../utils/islamic_commentaries_loader.js';
import { parseMarkdown } from '../../../../utils/markdown.js';
import { loadQuranContradictions } from '../../../../utils/quran_contradictions_loader.js';
import { loadScientificErrors, parseExplanationString } from '../../../../utils/quran_scientific_errors_loader.js';
import { loadDebunkingMiracles } from '../../../../utils/quran_debunking_loader.js';
import { formatCommentaryWithVerseBoxes, getRangeVerses } from '../../../../utils/quran_commentary_helpers.js';
import { getEvidenceSets } from '../../../../utils/quran_evidence_service.js';
import { enrichVideosWithVerses } from '../../../../utils/video_service.js';
import { R2_BASE_URL } from '../../../../utils/cdn_config.js';
import { BUILD_SURAHS } from '../../../../utils/build_config.js';

export async function getStaticPaths() {
  const {
    msQuranSet,
    footnotesSet,
    contradictionsSet,
    scientificErrorsSet,
    islamicCommentariesSet,
    debunkingSet,
    videosSet
  } = getEvidenceSets();

  const paths = [];
  const addPaths = (set, tabName) => {
    set.forEach(id => {
      const [s, a] = id.split(':');
      if (s && a && (!BUILD_SURAHS || BUILD_SURAHS.has(s))) {
        paths.push({ params: { surah: s, ayah: a, tab: tabName } });
      }
    });
  };

  addPaths(msQuranSet, 'manuscripts');
  addPaths(footnotesSet, 'christian-footnotes');
  addPaths(contradictionsSet, 'contradictions');
  addPaths(scientificErrorsSet, 'scientific-errors');
  addPaths(islamicCommentariesSet, 'islamic-commentaries');
  addPaths(debunkingSet, 'debunking-miracles');
  addPaths(videosSet, 'videos');

  return paths;
}

const { surah, ayah, tab } = Astro.params;
const verseId = `${surah}:${ayah}`;

const msCountInfo = query("SELECT COUNT(DISTINCT image_name) as count FROM manuscript_per_verse_quran WHERE verse_id = :verseId", { verseId });
const msCount = msCountInfo.length > 0 ? msCountInfo[0].count : 0;

const footnotesMap = loadChristianFootnotes();
const christianFootnotes = footnotesMap[verseId] || [];
const christianFootnotesCount = christianFootnotes.length;

const islamicMap = loadIslamicCommentaries();
const islamicCommentaries = islamicMap[verseId] || [];
const islamicCommentariesCount = islamicCommentaries.length;

const quranContradictionsMap = loadQuranContradictions();
const verseContradictions = quranContradictionsMap[verseId] || [];
const contradictionsCount = verseContradictions.length;

const quranScientificErrorsMap = loadScientificErrors();
const rawVerseError = quranScientificErrorsMap[verseId];
const parsedScientificErrors = rawVerseError ? parseExplanationString(rawVerseError.explanation) : [];
const scientificErrorsCount = parsedScientificErrors.length > 0 ? 1 : 0;

const quranDebunkingMap = loadDebunkingMiracles();
const verseDebunking = quranDebunkingMap[verseId] || [];
const debunkingCount = verseDebunking.length;

const dbVerseId = verseId.replace(':', '_');
const vdCountInfo = query("SELECT COUNT(DISTINCT video_id) as count FROM short_per_verse WHERE verse_id = :dbVerseId", { dbVerseId });
const videosCount = vdCountInfo.length > 0 ? vdCountInfo[0].count : 0;

// 3. Rejoin and pass non-box paragraphs through Markdown parser
const englishData = loadEnglishData();
const verseTextObj = englishData[verseId];
const verseText = verseTextObj ? verseTextObj.text : '';

let manuscripts = [];

if (tab === 'manuscripts') {
  const rawManuscripts = query(`
    SELECT m.image_name, mm.* 
    FROM manuscript_per_verse_quran m 
    LEFT JOIN manuscripts_meta_quran mm ON m.ms_id = mm.ms_id 
    WHERE m.verse_id = :verseId
    ORDER BY mm.earliest_date ASC
  `, { verseId });

  manuscripts = assignManuscriptScanNames(rawManuscripts);
}

let videos = [];
if (tab === 'videos') {
  const rawVideos = query(`
    SELECT sm.* 
    FROM short_per_verse spv
    JOIN shorts_metadata sm ON spv.video_id = sm.video_id
    WHERE spv.verse_id = :dbVerseId
  `, { dbVerseId });
  videos = enrichVideosWithVerses(rawVideos, import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL);
}

// Generate OG Image
let ogImage = undefined;
const earliestMs = query(`
  SELECT m.ms_id, m.image_name 
  FROM manuscript_per_verse_quran m
  JOIN manuscripts_meta_quran mm ON m.ms_id = mm.ms_id
  WHERE m.verse_id = :verseId
  ORDER BY mm.earliest_date ASC
  LIMIT 1
`, { verseId });
if (earliestMs.length > 0 && earliestMs[0].image_name) {
  ogImage = `${R2_BASE_URL}/quran/${earliestMs[0].ms_id}/${encodeURIComponent(earliestMs[0].image_name)}`;
}

const { seoTitle, seoDescription } = generateQuranTabSEO({ 
  tab, 
  surah, 
  ayah, 
  manuscripts, 
  verseContradictions, 
  parsedScientificErrors, 
  verseDebunking, 
  islamicCommentaries 
});

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout 
  title={seoTitle} 
  description={seoDescription} 
  ogImage={ogImage} 
>
  <div class="verse-detail-container theme-quran">
    
    <header class="detail-header select-none">
      <a href={`${base}/quran/${surah}#${ayah}`} class="back-btn" aria-label="Go back to surah reader">
        <span class="back-arrow">
          <svg width="6" height="10" fill="none" stroke="currentColor" viewBox="0 0 6 10" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 9L1 5l4-4" />
          </svg>
        </span>
        <span>Surah {surah}</span>
      </a>
      
      <div style="display: flex; align-items: center; gap: 8px;">
        <h2 class="verse-drawer-title" style="color: var(--quran-primary);">
          Surah {surah}:{ayah}
        </h2>
        <button id="open-quran-tab-settings-btn" class="subtle-ellipsis-btn" aria-label="Customize Quran Verse View" title="Customize Tabs">
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 12a2 2 0 114 0 2 2 0 01-4 0zm8 0a2 2 0 114 0 2 2 0 01-4 0zm8 0a2 2 0 114 0 2 2 0 01-4 0z" />
          </svg>
        </button>
      </div>
    </header>

    {verseText && (
      <div class="verse-text-reminder select-text" style="border-left-color: var(--quran-primary);">
        "{verseText}"
      </div>
    )}

    <script is:inline>
      try { localStorage.setItem('ready_apologia_has_seen_full_evidence', 'true'); } catch (e) {}
    </script>
    <script>
      document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('open-quran-tab-settings-btn');
        if (btn) {
          btn.onclick = () => {
            window.dispatchEvent(new CustomEvent('open-quran-tab-settings'));
          };
        }
      });
    </script>

    <QuranVerseTabs 
      client:load 
      msCount={msCount}
      christianFootnotesCount={christianFootnotesCount}
      islamicCommentariesCount={islamicCommentariesCount}
      contradictionsCount={contradictionsCount}
      scientificErrorsCount={scientificErrorsCount}
      debunkingCount={debunkingCount}
      videosCount={videosCount}
      activeTab={tab}
      surah={surah}
      ayah={ayah}
    />
      
    <div class="tab-panels-window">
      {tab === 'debunking-miracles' && (
        <div class="contradiction-panel-container">
          {verseDebunking.map((item) => (
            <div class="contradiction-details-card">
              <div class="contradiction-summary-header">
                <span class="summary-title-main">
                  <span class="ct-scales-icon" style="color: var(--color-secondary);">
                    <svg viewBox="0 0 24 24" stroke-width="2" fill="none" stroke="currentColor" width="18" height="18">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 2l2 4 4-1-2 4 3 3-4 1 1 4-4-2-3 3-1-4-4 1 2-4-4-2 4-1-1-4 4 2 3-4z" />
                    </svg>
                  </span>
                  <span>Claimed Miracle: {item.miracle_category || "General"}</span>
                </span>
              </div>

              <div class="contradiction-card-content">
                {item.claim && (
                  <div class="debunking-claim-box">
                    <span class="debunking-claim-label">APOLOGIST CLAIM</span>
                    <p class="debunking-claim-text">"{item.claim}"</p>
                  </div>
                )}

                {item.refutation && (
                  <div class="debunking-refutation-section">
                    <h4 class="debunking-refutation-heading">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" style="color: #10b981;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                      <span>Refutation & Exegesis</span>
                    </h4>
                    <div class="ct-answer-body" style="margin-top: 8px;">
                      {item.refutation}
                    </div>
                  </div>
                )}

                {(item.classification || item.classification_explanation) && (
                  <details class="debunking-methodology-details">
                    <summary class="debunking-methodology-summary">
                      <span class="debunking-methodology-title">
                        <strong>{item.classification || "Analysis"}</strong>
                      </span>
                      <span class="info-icon-btn" title="Click for explanation" aria-label="Explanation info">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                      </span>
                    </summary>
                    {item.classification_explanation && (
                      <div class="debunking-methodology-body">
                        <p>{item.classification_explanation}</p>
                      </div>
                    )}
                  </details>
                )}
              </div>
            </div>
          ))}
        </div>
      )}
      {tab === 'islamic-commentaries' && (
        <div class="contradiction-panel-container">
          {islamicCommentaries.map((comm) => {
            const rangeVerses = getRangeVerses(comm.verse_range, surah);
            return (
            <div class="contradiction-details-card">
              <div class="contradiction-summary-header">
                <span class="summary-title-main">
                  <span class="ct-scales-icon" style="color: #0d9488;">
                    <svg viewBox="0 0 24 24" stroke-width="2.2" fill="none" stroke="currentColor" width="18" height="18">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                    </svg>
                  </span>
                  <span>{comm.title || "Tafsir Ibn Kathir"}</span>
                  {comm.verse_range && (
                    <span class="ic-range-pill">Verses {comm.verse_range}</span>
                  )}
                </span>
              </div>
              <div class="contradiction-card-content">
                {rangeVerses.length > 0 && (
                  <details class="ic-context-details">
                    <summary class="ic-context-summary">
                      <span>Show Full Scripture Context ({comm.verse_range}) — {rangeVerses.length} Verse{rangeVerses.length > 1 ? 's' : ''}</span>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
                    </summary>
                    <div class="ic-context-list">
                      {rangeVerses.map(rv => (
                        <div class="ic-context-item">
                          <div class="ic-context-num">Verse {rv.number}</div>
                          {rv.arabic && <p class="text-arabic" style="font-size: 18px; margin: 4px 0;" set:html={rv.arabic} />}
                          {rv.english && <p class="text-english" style="font-size: 14px; margin: 4px 0; color: var(--color-on-surface-variant);" set:html={rv.english} />}
                        </div>
                      ))}
                    </div>
                  </details>
                )}
                <div class="ct-answer-body" style="padding-top: 8px;" set:html={formatCommentaryWithVerseBoxes(comm.commentary)} />
                {comm.source_volume_page && (
                  <p class="footnote-source" style="margin-top: 16px; text-align: right; color: var(--color-on-surface-variant); font-size: 12px;">
                    — from <em>Tafsir Ibn Kathir ({comm.source_volume_page})</em>
                  </p>
                )}
              </div>
            </div>
            );
          })}

          <details class="ic-authority-banner">
            <summary class="ic-authority-title">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span>About this Source & Scholarly Authority (Tafsir Ibn Kathir)</span>
            </summary>
            <div class="ic-authority-body">
              <p><strong>Universal Sunni Consensus:</strong> <em>Tafsir al-Qur'an al-Azim</em> by Hafiz Ibn Kathir (701–774 AH / 1301–1373 AD) is universally regarded across all major schools of Sunni Islam (traditional, Salafi, Ash'ari) as the most authoritative classical exegesis. It is prized because it relies on <em>Tafsir bil-Ma'thur</em>—interpreting the Quran using the Quran itself, authentic Hadiths of Prophet Muhammad, and recorded statements of the early Companions (<em>Sahabah</em>).</p>
              <p style="margin-top: 8px;"><strong>Standard English Edition:</strong> This text is from the standard 10-volume English abridgment published by <strong>Dar-us-Salam Publications</strong> (supervised by Shaykh Safiur-Rahman Al-Mubarakpuri), which is the official, most widely distributed English Quranic commentary in mosques and Islamic libraries worldwide today.</p>
            </div>
          </details>
        </div>
      )}
      {tab === 'scientific-errors' && (
        <div class="contradiction-panel-container">
          {parsedScientificErrors.map((errorObject) => (
               <div class="contradiction-details-card">
                   <div class="contradiction-summary-header">
                     <span class="summary-title-main">
                       <span class="ct-scales-icon">
                         <svg viewBox="0 0 24 24" stroke-width="2" fill="none" stroke="currentColor" width="18" height="18">
                           <path stroke-linecap="round" stroke-linejoin="round" d="M6 18h8 M3 22h18 M14 22a7 7 0 1 0 0-14h-1 M9 14h2 M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2Z M12 6V3 M20 4v4m0 3v.01" />
                         </svg>
                       </span>
                       {errorObject.label}
                     </span>
                   </div>
                   {errorObject.text && (
                     <div class="contradiction-card-content">
                        <div class="ct-answer-body" style="padding-top: 16px;">
                          {errorObject.text}
                        </div>
                     </div>
                   )}
               </div>
          ))}
        </div>
      )}
      {tab === 'manuscripts' && (
        <div>
          <QuranManuscriptCarousel 
            client:load 
            manuscripts={manuscripts} 
            surah={surah} 
            ayah={ayah} 
            verseLabel={`Surah ${surah}:${ayah}`} 
          />
        </div>
      )}
      {tab === 'christian-footnotes' && (
        <div class="christian-footnotes-panel">
          {christianFootnotes.map((note) => (
            <div class="footnote-card">
              <div class="footnote-content" set:html={parseMarkdown(note.content)} />
              <p class="footnote-source">- from <em>The Quran with Christian Commentary: A Guide to Understanding the Scripture of Islam</em></p>
            </div>
          ))}
        </div>
      )}
      {tab === 'contradictions' && (
        <div class="contradiction-panel-container">
          {verseContradictions.map((ct) => {
            return (
                <div class="contradiction-details-card">
                  <div class="contradiction-summary-header">
                    <span class="summary-title-main">
                      <span class="ct-scales-icon">
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 11 3-11M15 6l3 11 3-11M12 3v18M6 6h12M12 3C8.5 3 5 4 5 4M12 3c3.5 0 7 1 7 1"/></svg>
                      </span>
                      {ct.evidence}
                    </span>
                  </div>
                  
                  <div class="contradiction-card-content">
                    <div class="ct-flex-boxes">
                      {ct.supporting_verses && ct.supporting_verses.length > 0 && (
                        <div class="ct-box">
                          <h4 class="ct-box-header" style="color: #10b981;">Supporting Verses</h4>
                          <div class="ct-verses-list">
                            {ct.supporting_verses.map(v => {
                              const [vs, va] = v.split(':');
                              const targetTextObj = englishData[v];
                              const targetText = targetTextObj ? targetTextObj.text : '';
                              return (
                                <div class="verse-text-reminder snippet-reminder snippet-supp">
                                  <a href={`${base}/quran/${vs}#${va}`} class="ct-verse-link" title="Tap to read this supporting verse">{`Surah ${v}`} &rarr;</a>
                                  {targetText && <span> "{targetText}"</span>}
                                </div>
                              );
                            })}
                          </div>
                        </div>
                      )}
                      
                      {ct.opposite_verses && ct.opposite_verses.length > 0 && (
                        <div class="ct-box">
                          <h4 class="ct-box-header" style="color: #ef4444;">Opposing Verses</h4>
                          <div class="ct-verses-list">
                            {ct.opposite_verses.map(v => {
                              const [vs, va] = v.split(':');
                              const targetTextObj = englishData[v];
                              const targetText = targetTextObj ? targetTextObj.text : '';
                              return (
                                <div class="verse-text-reminder snippet-reminder snippet-opp">
                                  <a href={`${base}/quran/${vs}#${va}`} class="ct-verse-link" title="Tap to read this contrasting verse">{`Surah ${v}`} &rarr;</a>
                                  {targetText && <span> "{targetText}"</span>}
                                </div>
                              );
                            })}
                          </div>
                        </div>
                      )}
                    </div>

                    <div class="ct-answer-body">
                      {ct.description}
                    </div>
                  </div>
                </div>
            );
          })}
        </div>
      )}
      {tab === 'videos' && (
        <div class="videos-panel-container">
          <VideosGrid videos={videos} />
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
	.verse-detail-container {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.detail-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-bottom: 1px solid var(--color-outline-variant);
		padding-bottom: 14px;
	}

	.back-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 12px;
		background-color: var(--color-surface-container-low);
		color: var(--color-on-surface-variant);
		border: 1px solid var(--color-outline-variant);
		border-radius: 8px;
		font-size: 11px;
		font-weight: 700;
		text-decoration: none;
		transition: all 0.15s ease;
	}
	.back-btn:hover {
		background-color: var(--color-outline-variant);
		color: var(--quran-primary, #10b981);
	}
	.back-arrow {
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.back-arrow svg {
		stroke: currentColor;
		fill: none;
	}

	.verse-drawer-title {
		font-family: var(--font-display);
		font-size: 22px;
		font-weight: 800;
		margin: 0;
		letter-spacing: -0.01em;
	}

	.verse-text-reminder {
		font-family: var(--font-display);
		font-size: 13px;
		line-height: 1.4;
		color: var(--color-on-surface-variant);
		font-style: italic;
		padding: 10px 14px;
		background-color: var(--color-surface-container-lowest);
		border-left: 3px solid var(--quran-primary, #10b981);
		border-radius: 0 8px 8px 0;
		margin-bottom: 4px;
	}

  .tab-panels-window { margin-top: 14px; }

  .christian-footnotes-panel {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footnote-card {
    padding: 16px;
    background-color: var(--color-surface);
    border: 1px solid var(--color-outline-variant);
    border-radius: 8px;
  }

  .footnote-content {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-on-surface);
    margin: 0 0 12px 0;
    white-space: normal;
  }

  .footnote-content :global(p) {
    margin: 0 0 12px 0;
  }
  .footnote-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .footnote-source {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-on-surface-variant);
    margin: 0;
    font-style: italic;
    opacity: 0.8;
  }

  /* Contradictions Styles matching Bible slightly */
  .contradiction-panel-container {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .contradiction-details-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-outline-variant);
    border-radius: 12px;
    overflow: hidden;
  }
  .contradiction-summary-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 16px;
    color: var(--color-on-surface);
    background-color: var(--color-surface);
  }
  .summary-title-main {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ct-scales-icon svg {
    display: block;
    color: #ef4444; 
  }
  .contradiction-card-content {
    background-color: var(--color-surface-container-lowest);
    padding: 0 20px 20px 20px;
  }
  .ct-flex-boxes {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
    margin-top: 10px;
  }
  @media (min-width: 600px) {
    .ct-flex-boxes {
      flex-direction: row;
    }
    .ct-box {
      flex: 1;
    }
  }
  .ct-box {
    padding: 0;
  }
  .ct-box-header {
    font-family: var(--font-body);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 800;
    margin: 0 0 8px 0;
    opacity: 0.7;
    color: var(--color-on-surface);
  }
  .ct-verses-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .ct-verse-link {
    display: inline-flex;
    align-items: center;
    padding: 3px 8px;
    background-color: rgba(0,0,0,0.05);
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 12.5px;
    font-weight: 600;
