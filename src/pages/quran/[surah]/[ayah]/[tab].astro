---
import fs from 'node:fs';
import path from 'node:path';

import Layout from '../../../../layouts/Layout.astro';
import QuranVerseTabs from '../../../../components/QuranVerseTabs.jsx';
import QuranManuscriptCarousel from '../../../../components/QuranManuscriptCarousel.jsx';
import { query } from '../../../../db.js';
import { loadEnglishData } from '../../../../utils/quran_loader.js';
import { assignManuscriptScanNames } from '../../../../utils/manuscript_utils.js';
import { loadChristianFootnotes } from '../../../../utils/christian_footnotes_loader.js';
import { parseMarkdown } from '../../../../utils/markdown.js';
import { loadQuranContradictions } from '../../../../utils/quran_contradictions_loader.js';
import { loadScientificErrors, parseExplanationString } from '../../../../utils/quran_scientific_errors_loader.js';

export async function getStaticPaths() {
  const msQuran = query("SELECT DISTINCT verse_id FROM manuscript_per_verse_quran").map(r => r.verse_id);

  const paths = [];

  msQuran.forEach(id => {
    const [s, a] = id.split(':');
    if (s && a) {
      paths.push({ params: { surah: s, ayah: a, tab: 'manuscripts' } });
    }
  });

  const footnotes = loadChristianFootnotes();
  Object.keys(footnotes).forEach(id => {
    const [s, a] = id.split(':');
    if (s && a) {
      paths.push({ params: { surah: s, ayah: a, tab: 'christian-footnotes' } });
    }
  });

  const contradictionsMap = loadQuranContradictions();
  Object.keys(contradictionsMap).forEach(id => {
    const [s, a] = id.split(':');
    if (s && a) {
      paths.push({ params: { surah: s, ayah: a, tab: 'contradictions' } });
    }
  });

  const scientificErrorsMap = loadScientificErrors();
  Object.keys(scientificErrorsMap).forEach(id => {
    const [s, a] = id.split(':');
    if (s && a) {
      paths.push({ params: { surah: s, ayah: a, tab: 'scientific-errors' } });
    }
  });

  return paths;
}

const { surah, ayah, tab } = Astro.params;
const verseId = `${surah}:${ayah}`;

const msCountInfo = query("SELECT COUNT(DISTINCT image_name) as count FROM manuscript_per_verse_quran WHERE verse_id = :verseId", { verseId });
const msCount = msCountInfo.length > 0 ? msCountInfo[0].count : 0;

const footnotesMap = loadChristianFootnotes();
const christianFootnotes = footnotesMap[verseId] || [];
const christianFootnotesCount = christianFootnotes.length;

const quranContradictionsMap = loadQuranContradictions();
const verseContradictions = quranContradictionsMap[verseId] || [];
const contradictionsCount = verseContradictions.length;

const quranScientificErrorsMap = loadScientificErrors();
const rawVerseError = quranScientificErrorsMap[verseId];
const parsedScientificErrors = rawVerseError ? parseExplanationString(rawVerseError.explanation) : [];
const scientificErrorsCount = parsedScientificErrors.length > 0 ? 1 : 0;


const englishData = loadEnglishData();
const verseTextObj = englishData[verseId];
const verseText = verseTextObj ? verseTextObj.text : '';

let manuscripts = [];

if (tab === 'manuscripts') {
  const rawManuscripts = query(`
    SELECT m.image_name, mm.* 
    FROM manuscript_per_verse_quran m 
    LEFT JOIN manuscripts_meta_quran mm ON m.ms_id = mm.ms_id 
    WHERE m.verse_id = :verseId
    ORDER BY mm.earliest_date ASC
  `, { verseId });

  manuscripts = assignManuscriptScanNames(rawManuscripts);
}

// Generate OG Image
let ogImage = undefined;
const earliestMs = query(`
  SELECT m.ms_id, m.image_name 
  FROM manuscript_per_verse_quran m
  JOIN manuscripts_meta_quran mm ON m.ms_id = mm.ms_id
  WHERE m.verse_id = :verseId
  ORDER BY mm.earliest_date ASC
  LIMIT 1
`, { verseId });
if (earliestMs.length > 0 && earliestMs[0].image_name) {
  ogImage = `https://pub-219566f197174e27a10f51e5fb2414f6.r2.dev/quran/${earliestMs[0].ms_id}/${encodeURIComponent(earliestMs[0].image_name)}`;
}

let seoDescription = `Explore ancient manuscript evidence for Quran Surah ${surah}:${ayah} in Ready Apologia.`;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout 
  title={`Evidence: Surah ${surah}:${ayah}`} 
  description={seoDescription} 
  ogImage={ogImage} 
>
  <div class="verse-detail-container theme-quran">
    
    <header class="detail-header select-none">
      <a href={`${base}/quran/${surah}#v-${ayah}`} class="back-btn" aria-label="Go back to surah reader">
        <span class="back-arrow">
          <svg width="6" height="10" fill="none" stroke="currentColor" viewBox="0 0 6 10" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 9L1 5l4-4" />
          </svg>
        </span>
        <span>Surah {surah}</span>
      </a>
      
      <div style="display: flex; align-items: center; gap: 8px;">
        <h2 class="verse-drawer-title" style="color: var(--quran-primary);">
          Surah {surah}:{ayah}
        </h2>
      </div>
    </header>

    {verseText && (
      <div class="verse-text-reminder select-text" style="border-left-color: var(--quran-primary);">
        "{verseText}"
      </div>
    )}

    <QuranVerseTabs 
      client:load 
      msCount={msCount}
      christianFootnotesCount={christianFootnotesCount}
      contradictionsCount={contradictionsCount}
      scientificErrorsCount={scientificErrorsCount}
      activeTab={tab}
      surah={surah}
      ayah={ayah}
    />
      
    <div class="tab-panels-window">
      {tab === 'scientific-errors' && (
        <div class="contradiction-panel-container">
          {parsedScientificErrors.map((errorObject) => (
               <div class="contradiction-details-card">
                   <div class="contradiction-summary-header">
                     <span class="summary-title-main">
                       <span class="ct-scales-icon">
                         <svg viewBox="0 0 24 24" stroke-width="2" fill="none" stroke="currentColor" width="18" height="18">
                           <path stroke-linecap="round" stroke-linejoin="round" d="M6 18h8 M3 22h18 M14 22a7 7 0 1 0 0-14h-1 M9 14h2 M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2Z M12 6V3 M20 4v4m0 3v.01" />
                         </svg>
                       </span>
                       {errorObject.label}
                     </span>
                   </div>
                   {errorObject.text && (
                     <div class="contradiction-card-content">
                        <div class="ct-answer-body" style="padding-top: 16px;">
                          {errorObject.text}
                        </div>
                     </div>
                   )}
               </div>
          ))}
        </div>
      )}
      {tab === 'manuscripts' && (
        <div>
          <QuranManuscriptCarousel 
            client:load 
            manuscripts={manuscripts} 
            surah={surah} 
            ayah={ayah} 
            verseLabel={`Surah ${surah}:${ayah}`} 
          />
        </div>
      )}
      {tab === 'christian-footnotes' && (
        <div class="christian-footnotes-panel">
          {christianFootnotes.map((note) => (
            <div class="footnote-card">
              <div class="footnote-content" set:html={parseMarkdown(note.content)} />
              <p class="footnote-source">- from <em>The Quran with Christian Commentary: A Guide to Understanding the Scripture of Islam</em></p>
            </div>
          ))}
        </div>
      )}
      {tab === 'contradictions' && (
        <div class="contradiction-panel-container">
          {verseContradictions.map((ct) => {
            return (
                <div class="contradiction-details-card">
                  <div class="contradiction-summary-header">
                    <span class="summary-title-main">
                      <span class="ct-scales-icon">
                        <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 11 3-11M15 6l3 11 3-11M12 3v18M6 6h12M12 3C8.5 3 5 4 5 4M12 3c3.5 0 7 1 7 1"/></svg>
                      </span>
                      {ct.topic}
                    </span>
                  </div>
                  
                  <div class="contradiction-card-content">
                    <div class="ct-flex-boxes">
                      {ct.supporting_verses && ct.supporting_verses.length > 0 && (
                        <div class="ct-box">
                          <h4 class="ct-box-header" style="color: #10b981;">Supporting Verses</h4>
                          <div class="ct-verses-list">
                            {ct.supporting_verses.map(v => {
                              const [vs, va] = v.split(':');
                              const targetTextObj = englishData[v];
                              const targetText = targetTextObj ? targetTextObj.text : '';
                              return (
                                <div class="verse-text-reminder snippet-reminder snippet-supp">
                                  <a href={`${base}/quran/${vs}#v-${va}`} class="ct-verse-link" title="Tap to read this supporting verse">{`Surah ${v}`} &rarr;</a>
                                  {targetText && <span> "{targetText}"</span>}
                                </div>
                              );
                            })}
                          </div>
                        </div>
                      )}
                      
                      {ct.opposite_verses && ct.opposite_verses.length > 0 && (
                        <div class="ct-box">
                          <h4 class="ct-box-header" style="color: #ef4444;">Opposing Verses</h4>
                          <div class="ct-verses-list">
                            {ct.opposite_verses.map(v => {
                              const [vs, va] = v.split(':');
                              const targetTextObj = englishData[v];
                              const targetText = targetTextObj ? targetTextObj.text : '';
                              return (
                                <div class="verse-text-reminder snippet-reminder snippet-opp">
                                  <a href={`${base}/quran/${vs}#v-${va}`} class="ct-verse-link" title="Tap to read this contrasting verse">{`Surah ${v}`} &rarr;</a>
                                  {targetText && <span> "{targetText}"</span>}
                                </div>
                              );
                            })}
                          </div>
                        </div>
                      )}
                    </div>

                    <div class="ct-answer-body">
                      {ct.description}
                    </div>
                  </div>
                </div>
            );
          })}
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
	.verse-detail-container {
		display: flex;
		flex-direction: column;
		gap: 14px;
	}

	.detail-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-bottom: 1px solid var(--color-outline-variant);
		padding-bottom: 14px;
	}

	.back-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 12px;
		background-color: var(--color-surface-container-low);
		color: var(--color-on-surface-variant);
		border: 1px solid var(--color-outline-variant);
		border-radius: 8px;
		font-size: 11px;
		font-weight: 700;
		text-decoration: none;
		transition: all 0.15s ease;
	}
	.back-btn:hover {
		background-color: var(--color-outline-variant);
		color: var(--quran-primary, #10b981);
	}
	.back-arrow {
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.back-arrow svg {
		stroke: currentColor;
		fill: none;
	}

	.verse-drawer-title {
		font-family: var(--font-display);
		font-size: 22px;
		font-weight: 800;
		margin: 0;
		letter-spacing: -0.01em;
	}

	.verse-text-reminder {
		font-family: var(--font-display);
		font-size: 13px;
		line-height: 1.4;
		color: var(--color-on-surface-variant);
		font-style: italic;
		padding: 10px 14px;
		background-color: var(--color-surface-container-lowest);
		border-left: 3px solid var(--quran-primary, #10b981);
		border-radius: 0 8px 8px 0;
		margin-bottom: 4px;
	}

  .tab-panels-window { margin-top: 14px; }

  .christian-footnotes-panel {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footnote-card {
    padding: 16px;
    background-color: var(--color-surface);
    border: 1px solid var(--color-outline-variant);
    border-radius: 8px;
  }

  .footnote-content {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-on-surface);
    margin: 0 0 12px 0;
    white-space: normal;
  }

  .footnote-content :global(p) {
    margin: 0 0 12px 0;
  }
  .footnote-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .footnote-source {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-on-surface-variant);
    margin: 0;
    font-style: italic;
    opacity: 0.8;
  }

  /* Contradictions Styles matching Bible slightly */
  .contradiction-panel-container {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .contradiction-details-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-outline-variant);
    border-radius: 12px;
    overflow: hidden;
  }
  .contradiction-summary-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 16px;
    color: var(--color-on-surface);
    background-color: var(--color-surface);
  }
  .summary-title-main {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ct-scales-icon svg {
    display: block;
    color: #ef4444; 
  }
  .contradiction-card-content {
    background-color: var(--color-surface-container-lowest);
    padding: 0 20px 20px 20px;
  }
  .ct-flex-boxes {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
    margin-top: 10px;
  }
  @media (min-width: 600px) {
    .ct-flex-boxes {
      flex-direction: row;
    }
    .ct-box {
      flex: 1;
    }
  }
  .ct-box {
    padding: 0;
  }
  .ct-box-header {
    font-family: var(--font-body);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 800;
    margin: 0 0 8px 0;
    opacity: 0.7;
    color: var(--color-on-surface);
  }
  .ct-verses-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .ct-verse-link {
    display: inline-flex;
    align-items: center;
    padding: 3px 8px;
    background-color: rgba(0,0,0,0.05);
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 12.5px;
    font-weight: 600;
    color: var(--color-on-surface);
    text-decoration: none;
    transition: all 0.15s;
    margin-right: 6px;
    margin-bottom: 2px;
  }
  .ct-verse-link:hover {
    background-color: var(--color-primary);
    color: var(--color-surface);
  }
  .snippet-reminder {
    margin-left: 0;
    margin-bottom: 0;
    padding: 10px 14px;
    font-size: 13.5px;
    border-left-width: 3px;
    line-height: 1.5;
  }
  .snippet-supp {
    background-color: rgba(16, 185, 129, 0.05);
    border-left-color: rgba(16, 185, 129, 0.6) !important;
  }
  .snippet-opp {
    background-color: rgba(239, 68, 68, 0.05);
    border-left-color: rgba(239, 68, 68, 0.6) !important;
  }
  .ct-answer-body {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-on-surface);
    white-space: pre-wrap;
  }
</style>
