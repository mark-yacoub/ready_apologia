---
import Layout from '../../../../layouts/Layout.astro';
import { getQuranDatasets } from '../../../../utils/quran_data.js';
import { diffArabicWords } from '../../../../utils/diffUtils.js';

export async function getStaticPaths() {
  const { codices, canonical } = getQuranDatasets();
  
  const entities = new Set(['Hafs']);
  codices.forEach(c => c.variants.forEach(v => entities.add(v.companion_codex)));
  Object.values(canonical).forEach(variants => variants.forEach(v => entities.add(v.qari)));
  
  const entityArray = Array.from(entities);
  const paths = [];
  
  // Create NxN matrix of paths
  for (let i = 0; i < entityArray.length; i++) {
    for (let j = 0; j < entityArray.length; j++) {
      if (i !== j) {
        paths.push({
          params: { x: entityArray[i], y: entityArray[j] },
          props: { xName: entityArray[i], yName: entityArray[j] }
        });
      }
    }
  }
  
  return paths;
}

const { x, y } = Astro.params;
const { xName, yName } = Astro.props;

const { codices, canonical, droge, hafs } = getQuranDatasets();

// Get variants for an entity
function getVersesForEntity(entity) {
  const map = new Map();
  if (entity === 'Hafs') {
    // Hafs is the standard, it has every verse, but we only want to show verses where the OTHER entity has a variant.
    // So we don't pre-populate Hafs with everything, we will dynamically pull Hafs when iterating the union.
    return map;
  }
  
  // Check codices
  codices.forEach(c => {
    const variant = c.variants.find(v => v.companion_codex === entity);
    if (variant) {
      map.set(`${c.surah}:${c.ayah}`, {
        arabic: variant.variant_arabic,
        english: variant.variant_english,
        source: variant.source_reference
      });
    }
  });
  
  // Check canonical
  for (const [hafsId, variants] of Object.entries(canonical)) {
    const variant = variants.find(v => v.qari === entity);
    if (variant) {
      map.set(hafsId, {
        arabic: variant.qari_arabic,
        english: null,
        source: variant.change_category
      });
    }
  }
  return map;
}

const xVerses = getVersesForEntity(xName);
const yVerses = getVersesForEntity(yName);

// Union of verse IDs where either X or Y has a variant
const allIds = new Set([...xVerses.keys(), ...yVerses.keys()]);

const diffList = [];
allIds.forEach(id => {
  const [surah, ayah] = id.split(':');
  
  const xData = xVerses.get(id) || { 
    arabic: hafs[id] || "", 
    english: droge[id] ? droge[id].text : "",
    source: "Standard (Hafs)"
  };
  
  const yData = yVerses.get(id) || { 
    arabic: hafs[id] || "", 
    english: droge[id] ? droge[id].text : "",
    source: "Standard (Hafs)"
  };
  
  let xArabicRendered = xData.arabic;
  let yArabicRendered = yData.arabic;
  
  if (surah !== '0' && surah !== 'unknown') {
     try {
       const diff = diffArabicWords(xData.arabic, yData.arabic);
       xArabicRendered = diff.rendered1;
       yArabicRendered = diff.rendered2;
     } catch (e) {
       console.error("Diff failed for", id, e);
     }
  }
  
  diffList.push({ surah, ayah, xData, yData, xArabicRendered, yArabicRendered });
});

// Sort verses
diffList.sort((a, b) => {
  const surahA = a.surah === 'unknown' ? 0 : parseInt(a.surah);
  const surahB = b.surah === 'unknown' ? 0 : parseInt(b.surah);
  if (surahA !== surahB) return surahA - surahB;
  return parseInt(a.ayah) - parseInt(b.ayah);
});

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout title={`Quran Diff: ${xName.replace(/_/g, ' ')} vs ${yName.replace(/_/g, ' ')}`}>
  <style is:inline>
    :root {
      --color-primary: #2e7d32;
      --color-secondary: #a0522d;
    }
  </style>
  <div class="diff-page-container">
    <header class="diff-header" style="padding: 24px; background: var(--color-surface-container-low); border-bottom: 1px solid var(--color-outline-variant); border-radius: 12px; margin: 16px;">
      <h1 style="font-size: 24px; font-weight: 700; color: var(--color-on-surface); margin-bottom: 8px;">
        Comparing Texts
      </h1>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 16px;">
        <div style="flex: 1; text-align: center; font-size: 18px; font-weight: bold; color: var(--color-primary); padding: 8px; border: 1px solid var(--color-primary); border-radius: 8px; background: rgba(0,255,0,0.05);">
          {xName.replace(/_/g, ' ')}
        </div>
        <div style="padding: 0 16px; font-weight: bold; color: var(--color-on-surface-variant);">VS</div>
        <div style="flex: 1; text-align: center; font-size: 18px; font-weight: bold; color: var(--color-secondary); padding: 8px; border: 1px solid var(--color-secondary); border-radius: 8px; background: rgba(255,0,0,0.05);">
          {yName.replace(/_/g, ' ')}
        </div>
      </div>
      <p style="margin-top: 16px; font-size: 14px; color: var(--color-on-surface-variant); text-align: center;">
        Showing {diffList.length} verses where at least one of these sources diverges.
      </p>
    </header>

    <div class="verses-list" style="padding: 16px;">
      {diffList.map(v => (
        <div class="verse-card" style="margin-bottom: 24px; border: 1px solid var(--color-outline-variant); border-radius: 8px; overflow: hidden;">
          <div class="verse-header" style="background: var(--color-surface-container); padding: 8px 16px; display: flex; justify-content: space-between; align-items: center;">
            <a href={`${base}/quran/${v.surah === 'unknown' ? 0 : v.surah}#${v.ayah}`} style="font-weight: bold; color: var(--color-on-surface); text-decoration: none;">
              Surah {v.surah === 'unknown' ? 'Lost Verses' : v.surah}, Ayah {v.ayah}
            </a>
          </div>
          
          <div class="verse-comparison" style="display: flex; gap: 0; min-height: 150px;">
            <div class="x-side" style="flex: 1; padding: 16px; border-right: 1px dashed var(--color-outline-variant); background: var(--color-surface);">
              <div style="direction: rtl; font-family: 'Amiri', serif; font-size: 22px; line-height: 1.8; color: var(--color-primary); margin-bottom: 12px;" set:html={v.xArabicRendered}>
              </div>
              {v.xData.english && (
                <div style="font-size: 15px; line-height: 1.6; color: var(--color-on-surface);">
                  {v.xData.english}
                </div>
              )}
              <div style="margin-top: 12px; font-size: 11px; color: var(--color-on-surface-variant);">
                Source: {v.xData.source}
              </div>
            </div>
            
            <div class="y-side" style="flex: 1; padding: 16px; background: var(--color-surface-container-low);">
              <div style="direction: rtl; font-family: 'Amiri', serif; font-size: 22px; line-height: 1.8; color: var(--color-secondary); margin-bottom: 12px;" set:html={v.yArabicRendered}>
              </div>
              {v.yData.english && (
                <div style="font-size: 15px; line-height: 1.6; color: var(--color-on-surface);">
                  {v.yData.english}
                </div>
              )}
              <div style="margin-top: 12px; font-size: 11px; color: var(--color-on-surface-variant);">
                Source: {v.yData.source}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>

