---
import Layout from '../../layouts/Layout.astro';
import { getQuranDatasets } from '../../utils/quran_data.js';

export async function getStaticPaths() {
  const { codices, canonical } = getQuranDatasets();
  
  const companions = new Set();
  codices.forEach(c => c.variants.forEach(v => companions.add(v.companion_codex)));
  
  const qaris = new Set();
  Object.values(canonical).forEach(variants => variants.forEach(v => qaris.add(v.qari)));
  
  const paths = [];
  companions.forEach(c => {
    paths.push({
      params: { person: c },
      props: { isCompanion: true, name: c.replace(/_/g, ' ') }
    });
  });
  
  qaris.forEach(q => {
    paths.push({
      params: { person: q },
      props: { isCompanion: false, name: q.replace(/_/g, ' ') }
    });
  });
  
  return paths;
}

const { person } = Astro.params;
const { isCompanion, name } = Astro.props;

// Filter verses for this person
const { codices, canonical, droge, hafs } = getQuranDatasets();

const personVerses = [];

if (isCompanion) {
  codices.forEach(c => {
    const variant = c.variants.find(v => v.companion_codex === person);
    if (variant) {
      personVerses.push({
        surah: c.surah,
        ayah: c.ayah,
        baseEnglish: droge[`${c.surah}:${c.ayah}`] ? droge[`${c.surah}:${c.ayah}`].text : "No standard translation available.",
        baseArabic: hafs[`${c.surah}:${c.ayah}`] || "",
        variantEnglish: variant.variant_english,
        variantArabic: variant.variant_arabic,
        source: variant.source_reference,
        url: variant.sunnah_url
      });
    }
  });
} else {
  // It's a qari
  for (const [hafsId, variants] of Object.entries(canonical)) {
    const variant = variants.find(v => v.qari === person);
    if (variant) {
      const [surah, ayah] = hafsId.split(':');
      personVerses.push({
        surah,
        ayah,
        baseEnglish: droge[hafsId] ? droge[hafsId].text : "No standard translation available.",
        baseArabic: hafs[hafsId] || "",
        variantArabic: variant.qari_arabic,
        reason: variant.reason_of_change,
        category: variant.change_category
      });
    }
  }
}

// Sort verses (Lost verses surah='unknown' should probably come first, but standard surahs are string numbers)
personVerses.sort((a, b) => {
  const surahA = a.surah === 'unknown' ? 0 : parseInt(a.surah);
  const surahB = b.surah === 'unknown' ? 0 : parseInt(b.surah);
  if (surahA !== surahB) return surahA - surahB;
  return parseInt(a.ayah) - parseInt(b.ayah);
});

// Calculate metrics
const totalVariants = personVerses.length;
const totalSurahs = new Set(personVerses.map(v => v.surah)).size;

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout title={`Quran Variants: ${name}`}>
  <style is:inline>
    :root {
      --color-primary: #2e7d32;
      --color-secondary: #a0522d;
    }
  </style>
  <div class="person-page-container">
    <header class="person-header" style="padding: 24px; background: var(--color-surface-container-low); border-bottom: 1px solid var(--color-outline-variant); border-radius: 12px; margin: 16px;">
      <h1 style="font-size: 24px; font-weight: 700; color: var(--color-on-surface); margin-bottom: 8px;">
        {name}
      </h1>
      <div class="metrics" style="display: flex; gap: 16px; font-size: 14px; color: var(--color-on-surface-variant);">
        <span><strong>{totalVariants}</strong> Variants</span>
        <span><strong>{totalSurahs}</strong> Surahs affected</span>
      </div>
      <p style="margin-top: 16px; font-size: 14px; color: var(--color-on-surface);">
        {isCompanion 
          ? "This is a collection of non-Uthmanic verses attributed to this companion, representing a parallel narrative and set of text compared to the Uthmanic standard."
          : "This is a collection of canonical recitations attributed to this Qari, representing variations in pronunciation, diacritics, and meaning while maintaining the same Rasm (consonantal skeleton)."}
      </p>
    </header>

    <div class="verses-list" style="padding: 16px;">
      {personVerses.map(v => (
        <div class="verse-card" style="margin-bottom: 24px; border: 1px solid var(--color-outline-variant); border-radius: 8px; overflow: hidden;">
          <div class="verse-header" style="background: var(--color-surface-container); padding: 8px 16px; display: flex; justify-content: space-between; align-items: center;">
            <a href={`${base}/quran/${v.surah === 'unknown' ? 0 : v.surah}#${v.ayah}`} style="font-weight: bold; color: var(--color-primary); text-decoration: none;">
              Surah {v.surah === 'unknown' ? 'Lost Verses' : v.surah}, Ayah {v.ayah}
            </a>
          </div>
          
          <div class="verse-comparison" style="display: flex; flex-direction: column; gap: 0;">
            <div class="hafs-side" style="padding: 16px; border-bottom: 1px dashed var(--color-outline-variant); background: var(--color-surface);">
              <div style="font-size: 12px; font-weight: 600; color: var(--color-on-surface-variant); margin-bottom: 8px; text-transform: uppercase;">Standard (Hafs)</div>
              <div style="direction: rtl; font-family: 'Amiri', serif; font-size: 24px; line-height: 1.8; color: var(--color-on-surface);">
                {v.baseArabic}
              </div>
              <div style="margin-top: 8px; font-size: 16px; line-height: 1.6; color: var(--color-on-surface-variant);">
                {v.baseEnglish}
              </div>
            </div>
            
            <div class="variant-side" style="padding: 16px; background: var(--color-surface-container-low);">
              <div style="font-size: 12px; font-weight: 600; color: var(--color-secondary); margin-bottom: 8px; text-transform: uppercase;">{name}</div>
              {v.variantArabic && (
                <div style="direction: rtl; font-family: 'Amiri', serif; font-size: 24px; line-height: 1.8; color: var(--color-secondary);">
                  {v.variantArabic}
                </div>
              )}
              {isCompanion && (
                <div style="margin-top: 8px; font-size: 16px; line-height: 1.6; color: var(--color-secondary);">
                  {v.variantEnglish}
                </div>
              )}
              
              {!isCompanion && (
                <div style="margin-top: 8px; font-size: 14px; color: var(--color-on-surface);">
                  <strong>Reason:</strong> {v.reason} <br/>
                  <strong>Category:</strong> {v.category}
                </div>
              )}
              
              {isCompanion && (
                <div style="margin-top: 12px; font-size: 12px; color: var(--color-on-surface-variant);">
                  <a href={v.url} target="_blank" style="text-decoration: underline;">{v.source}</a>
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
