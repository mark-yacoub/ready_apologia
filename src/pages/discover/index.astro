---
import Layout from '../../layouts/Layout.astro';
import DiscoverCard from '../../components/DiscoverCard.astro';
import ComingSoonBanner from '../../components/ComingSoonBanner.astro';
import discoverData from '../../data/discoverCatalog.json';
import { clusterCatalogData } from '../../utils/discoverService';

// Safely inject dependencies into the pure service core
const clusteredCatalog = clusterCatalogData(discoverData as unknown[]);
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

const pageDesc = "Explore deep dives and historical timelines regarding Christianity and Islam.";
const pageKeywords = "discover, apologetics";
---

<Layout title="Discover | Ready Apologia" description={pageDesc} keywords={pageKeywords}>
  <div class="discover-hub">
    <header class="hub-header">
      <h1 class="hub-title">Discover</h1>
      <p class="hub-subtitle">Deep dive into topics drawn from historical and scriptural sources.</p>
    </header>

    <div class="categories-container" id="discover-panels">
      {clusteredCatalog.map((categoryGroup) => {
        const safeId = categoryGroup.name.toLowerCase().replace(/\s+/g, '-');
        return (
          <div 
            id={`panel-${safeId}`}
            class="major-category-block animate-fade-in" 
            data-category={categoryGroup.name} 
          >
          <div class="major-category-header">
            <h2 class="major-category-title">{categoryGroup.name}</h2>
          </div>
          
          <div class="subcategories-container">
            {categoryGroup.subcategories.map((subGroup) => (
              <section class="discover-section">
                <div class="section-header">
                  <h3 class="section-title">{subGroup.name}</h3>
                </div>
                <div class="cards-scroller">
                  {subGroup.articles.map((card) => (
                    <DiscoverCard card={card} base={base} />
                  ))}
                </div>
              </section>
            ))}
          </div>
        </div>
      );
    })}
    </div>

    <ComingSoonBanner url="https://forms.gle/KVeeDW41J9zqJtdZ7" />

  </div>
</Layout>



<style>
  .discover-hub {
    display: flex;
    flex-direction: column;
    padding-bottom: 24px;
    animation: fadeIn 0.3s ease-out forwards;
  }
  
  .hub-header {
    padding: 24px 0 0 0;
  }
  
  .hub-title {
    font-size: 30px;
    font-weight: 900;
    margin: 0 20px 6px 20px;
    color: var(--color-primary, #1e293b);
    letter-spacing: -0.02em;
    font-family: var(--font-headings, inherit);
  }
  
  .hub-subtitle {
    font-size: 14px;
    color: var(--color-on-surface-variant, #64748b);
    margin: 0 20px 0 20px;
    line-height: 1.5;
    font-family: var(--font-body, inherit);
  }

  .category-tabs-wrapper {
    margin-top: 16px;
    width: 100%;
  }

  .master-tabs-container {
    display: flex;
    gap: 12px;
    border-bottom: 2px solid #e2e8f0;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 0 20px;
  }
  
  .master-tabs-container::-webkit-scrollbar {
    display: none;
  }

  .master-tab {
    background: none;
    border: none;
    padding: 12px 16px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    color: #64748b;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .master-tab:hover {
    color: #334155;
  }

  .master-tab.active {
    color: #0f172a;
    border-bottom-color: var(--evidence-color, var(--color-secondary, #974543));
  }

  .categories-container {
    padding-top: 16px; 
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .major-category-block {
    display: flex;
    flex-direction: column;
    padding: 0 20px;
  }

  .major-category-header {
    margin-bottom: 24px;
    border-bottom: 3px solid #cbd5e1;
    padding-bottom: 12px;
  }

  .major-category-title {
    font-size: 32px;
    font-weight: 800;
    margin: 0;
    color: var(--color-on-surface, #09090b);
    font-family: var(--font-display, Georgia, serif);
    letter-spacing: -0.5px;
  }

  .subcategories-container {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .section-header {
    margin-bottom: 12px;
  }

  .section-title {
    font-family: var(--font-cinzel, 'Times New Roman', serif);
    font-size: 22px;
    font-weight: 600;
    color: var(--color-on-surface-variant, #475569);
    margin: 0 0 12px 0;
    position: relative;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 1px;
    background-color: var(--color-outline-variant, #cbd5e1);
    margin: 8px 0 0 0;
  }

  /* Horizontal scrolling for native touch devices */
  .cards-scroller {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 16px;
    padding: 0 20px 24px 20px; /* Padding bottom for shadow clearance */
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  
  .cards-scroller::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }



  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.3s ease-out forwards;
  }
</style>
