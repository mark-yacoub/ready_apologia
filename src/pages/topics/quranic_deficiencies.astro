---
import Layout from '../../layouts/Layout.astro';
import QuranicTopicsExplorer from '../../components/QuranicTopicsExplorer.jsx';
import verseLabelsObj from '../../data/quran/verse_labels.json';
import drogeTranslation from '../../data/quran/english/droge_translation.json';
import { loadAllTopicsData } from '../../utils/topicsLoader.js';

// We load all topics solely to populate the generic top-of-page Dropdown selector,
// so users can still switch from "Quranic Deficiencies" back to "Divinity of Christ".
const topicsDropdownData = loadAllTopicsData();
const topicTitle = "Quranic Deficiencies & Evidence";
const topicDesc = "Analyzing theological and historical deficiencies in the Quran via direct scripture evidence.";
---

<Layout title={topicTitle} description={topicDesc} theme="quran">
  <div class="topic-page-container">
    <QuranicTopicsExplorer 
      client:load 
      topicsDropdownData={topicsDropdownData} 
      verseLabels={verseLabelsObj} 
      drogeTranslation={drogeTranslation} 
    />
  </div>
</Layout>

<style>
  .topic-page-container {
    display: flex;
    flex-direction: column;
    padding-top: 12px;
    min-height: 100%;
  }
</style>
