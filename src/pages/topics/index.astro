---
import Layout from '../../layouts/Layout.astro';
import TopicsExplorer from '../../components/TopicsExplorer.jsx';
import { loadAllTopicsData } from '../../utils/topicsLoader.js';

const topicsData = loadAllTopicsData();

const pageDesc = "Comprehensive directory of Christian apologetics topics. Explore Biblical Scripture proofs and early Church Patristic testimonies defending core doctrines like the Divinity of Christ.";
const pageKeywords = "verses divinity of christ, bible verses divinity of christ, apologetics topics, scripture evidence ready apologia, ante-nicene fathers divinity of christ";

const schemaObj = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "headline": "Christian Apologetics Topics & Scripture Evidence",
  "description": pageDesc,
  "hasPart": topicsData.map(t => ({
    "@type": "WebPage",
    "name": t.topicId.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()),
    "url": `${Astro.url.origin}${import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL}/topics/${t.topicId}`
  }))
};
const schemaJson = JSON.stringify(schemaObj);
---

<Layout title="Apologetics Topics" description={pageDesc} keywords={pageKeywords} schema={schemaJson}>
  <div class="topics-index-container">
    <TopicsExplorer client:load topics={topicsData} />
  </div>
</Layout>

<style>
  .topics-index-container {
    display: flex;
    flex-direction: column;
    padding-top: 12px;
  }
</style>
