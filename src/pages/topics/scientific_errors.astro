---
import Layout from '../../layouts/Layout.astro';
import ScientificErrorsExplorer from '../../components/ScientificErrorsExplorer.jsx';
import scientificErrorsObj from '../../data/quran/scientific_errors/scientific_errors.json';
import drogeTranslation from '../../data/quran/english/droge_translation.json';
import { loadAllTopicsData } from '../../utils/topicsLoader.js';

// We load all topics solely to populate the generic top-of-page Dropdown selector
const topicsDropdownData = loadAllTopicsData();
const topicTitle = "Scientific Errors in the Quran";
const topicDesc = "Analyzing scientific errors and historical cosmological miscalculations in the Quran.";
---

<Layout title={topicTitle} description={topicDesc} theme="quran">
  <div class="topic-page-container">
    <ScientificErrorsExplorer 
      client:load 
      topicsDropdownData={topicsDropdownData} 
      scientificErrors={scientificErrorsObj} 
      drogeTranslation={drogeTranslation} 
    />
  </div>
</Layout>

<style>
  .topic-page-container {
    display: flex;
    flex-direction: column;
    padding-top: 12px;
    min-height: 100%;
  }
</style>
